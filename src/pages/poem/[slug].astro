---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getAllPoems, getPoemBySlug, slugify } from '../../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://anattanergui.github.io/barking';

export async function getStaticPaths() {
  const poems = getAllPoems();
  return poems.map((p, i) => ({
    params: { slug: p.slug },
    props: {
      poem: p,
      prevPoem: poems[i - 1] ?? null,
      nextPoem: poems[i + 1] ?? null,
      allPoems: poems,
    },
  }));
}

const { poem, prevPoem, nextPoem, allPoems } = Astro.props;
const { title, atmosphere, crux, domains, ground, related, content, wordCount } = poem;

const metaParts = [
  atmosphere.length > 0 ? atmosphere.join(', ') : null,
  crux.length       > 0 ? crux.join(', ')       : null,
  domains.length    > 0 ? domains.join(', ')     : null,
].filter(Boolean);
const generatedDescription = metaParts.length
  ? `${title} — ${metaParts.join(' · ')}`
  : `${title} — a poem`;
const description = poem.description || generatedDescription;

// Convert markdown line breaks to HTML stanzas
const stanzas = content.split(/\n{2,}/);
const bodyHtml = stanzas
  .map(s => s.split('\n').filter(l => !l.startsWith('#')).join('\n'))
  .filter(s => s.trim())
  .map(s => `<p>${s.replace(/\n/g, '<br>')}</p>`)
  .join('\n');

// Resolve related slugs (frontmatter may store titles rather than slugs)
const relatedPoems = related
  .map(r => allPoems.find(p => p.slug === slugify(r) || p.title === r))
  .filter(Boolean)
  .slice(0, 6);

// ── JSON-LD schema ────────────────────────────────────────────────────────────
// Plain text content for the schema (strip markdown headings)
const plainText = content
  .split('\n')
  .filter(l => !l.startsWith('#'))
  .join('\n')
  .trim();

const keywords = [
  ...atmosphere,
  ...crux,
  ...domains,
  ...ground,
  ...(poem.tags || []),
].filter(Boolean).join(', ');

const poemUrl = `${siteUrl}/poem/${poem.slug}/`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Poem',
  name: title,
  description: description,
  text: plainText,
  url: poemUrl,
  author: {
    '@type': 'Person',
    name: 'Anatta Nergui',
    url: siteUrl,
  },
  isPartOf: {
    '@type': 'Book',
    name: 'Barking',
    url: siteUrl,
    author: {
      '@type': 'Person',
      name: 'Anatta Nergui',
    },
  },
  ...(keywords ? { keywords } : {}),
  ...(wordCount > 0 ? { wordCount } : {}),
};
---
<Base {title} {description}>
  <JsonLd slot="head" schema={schema} />

<style>
  .poem-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    min-height: calc(100vh - var(--nav-h));
  }

  /* Reading column */
  .poem-col {
    padding: 5rem 6rem;
    max-width: 680px;
  }

  .back {
    display: inline-flex; 
    align-items: center; 
    gap: 0.4rem;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 3.5rem;
    transition: color 0.2s;
  }
  .back:hover { color: var(--ink); }

  .poem-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 4rem;
  }

  .poem-body {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.05rem;
    line-height: 2.3;
    font-weight: 400;
  }
  .poem-body :global(p) {
    margin-bottom: 1.5rem;
  }
  .poem-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Action buttons after poem content */
  .poem-actions {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .action-btn {
    font-family: 'Karla', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .action-btn::before { 
    font-size: 1rem; 
    line-height: 1;
  }
  .bookmark-btn::before { 
    content: '✒'; 
  }
  .bookmark-btn.bookmarked {
    color: var(--ink);
  }
  .bookmark-btn.bookmarked::before { 
    content: '✒'; 
  }
  .send-btn::before {
    content: '↗';
  }
  .action-btn:hover { 
    color: var(--ink); 
  }

  /* Send dropdown - appears directly below the button */
  .send-dropdown {
    display: none;
    position: absolute;
    bottom: 100%;
    left: 0;
    margin-bottom: 0.5rem;
    background: var(--bg-panel);
    border: 1px solid var(--rule);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    z-index: 1000;
    min-width: 200px;
  }
  
  .send-dropdown.open {
    display: block;
  }

  .send-option {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.9rem 1.1rem;
    background: none;
    border: none;
    border-bottom: 1px solid var(--rule);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
    text-decoration: none;
    color: var(--ink);
    width: 100%;
    font-family: 'Karla', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  
  .send-option:last-child {
    border-bottom: none;
  }
  
  .send-option:hover {
    background: var(--stat-hover);
  }

  .send-icon {
    font-size: 1.1rem;
    line-height: 1;
    width: 20px;
    text-align: center;
    flex-shrink: 0;
  }

  /* Action buttons container needs position relative for dropdown */
  .poem-actions {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
  }

  /* Copy feedback toast */
  .copy-feedback {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--btn-bg);
    color: var(--btn-ink);
    padding: 1rem 1.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    z-index: 3000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .copy-feedback.show {
    opacity: 1;
  }

  /* Sidebar column */
  .sidebar-col {
    background: var(--bg-panel);
    border-left: 1px solid var(--rule);
    padding: 5rem 2.5rem;
    overflow-y: auto;
    max-height: calc(100vh - var(--nav-h));
    position: sticky;
    top: var(--nav-h);
  }

  .s-label {
    display: block;
    font-family: 'Karla', sans-serif;
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.8rem;
    position: relative;
    cursor: default;
  }

  .s-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.8rem;
  }

  .tag {
    display: inline-block;
    font-family: 'Karla', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--tag-ink);
    background: var(--tag-bg);
    padding: 0.3rem 0.8rem;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .tag:hover {
    background: var(--accent);
    color: var(--paper);
  }

  .s-value {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.9rem;
    color: var(--ink);
    margin-bottom: 1.8rem;
  }

  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .related-item {
    margin-bottom: 0;
  }
  .related-item a {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.78rem;
    color: var(--ink);
    background: var(--tag-bg);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    display: inline-block;
    padding: 0.4rem 0.9rem;
    line-height: 1.4;
  }
  .related-item a:hover {
    background: var(--accent);
    color: var(--paper);
  }

  /* Adjacent poem navigation */
  /* Next poem - appears in sidebar between nav and metadata */
  .next-poem {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .next-label {
    font-family: 'Karla', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: 0.8rem;
  }

  .next-link {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--ink);
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.2s;
    display: block;
  }

  .next-link:hover {
    color: var(--accent);
  }

  /* Mobile adjustments */
  @media (max-width: 1100px) {
    .poem-layout {
      grid-template-columns: 1fr;
    }

    .sidebar-col {
      position: static;
      max-height: none;
      border-left: none;
      border-top: 1px solid var(--rule);
      padding: 3rem 2rem;
    }

    .poem-col {
      padding: 3rem 2rem;
    }
  }

  @media (max-width: 700px) {
    .poem-col {
      padding: 2.5rem 1.5rem;
    }

    .sidebar-col {
      padding: 2.5rem 1.5rem;
    }

    .poem-title {
      font-size: 2rem;
      margin-bottom: 3rem;
    }

    .poem-body {
      font-size: 1rem;
      line-height: 2;
    }

    .action-btn {
      font-size: 0.6rem;
      padding: 0.6rem 1rem;
    }

    .nav-poem {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
  }
</style>

<div class="poem-layout">
  <div class="poem-col">
    <a href={`${base}/browse`} class="back">
      <span>←</span>
      <span>Back to collection</span>
    </a>

    <h1 class="poem-title">{title}</h1>

    <div class="poem-body" set:html={bodyHtml} />

    <div class="poem-actions">
      <button 
        class="action-btn bookmark-btn" 
        id="bookmark-btn"
        aria-label="Mark this poem"
      >
        <span>Mark</span>
      </button>
      <div style="position: relative;">
        <button 
          class="action-btn send-btn" 
          id="send-btn"
          aria-label="Share this poem"
        >
          <span>Send</span>
        </button>
        <div class="send-dropdown" id="send-dropdown">
          <button class="send-option" id="copy-link">
            <span class="send-icon">🔗</span>
            <span>Copy Link</span>
          </button>
          <a class="send-option" id="email-share" href="">
            <span class="send-icon">✉️</span>
            <span>Email</span>
          </a>
          <a class="send-option" id="twitter-share" href="" target="_blank" rel="noopener noreferrer">
            <span class="send-icon">𝕏</span>
            <span>Post on X</span>
          </a>
          <a class="send-option" id="facebook-share" href="" target="_blank" rel="noopener noreferrer">
            <span class="send-icon">f</span>
            <span>Facebook</span>
          </a>
          <a class="send-option" id="whatsapp-share" href="" target="_blank" rel="noopener noreferrer">
            <span class="send-icon">💬</span>
            <span>WhatsApp</span>
          </a>
          <button class="send-option" id="native-share" style="display: none;">
            <span class="send-icon">↗</span>
            <span>Share...</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <aside class="sidebar-col">
    {atmosphere.length > 0 && (
      <>
        <span class="s-label">Atmosphere</span>
        <div class="s-tags">
          {atmosphere.map(m => (
            <a href={`${base}/browse?atmosphere=${encodeURIComponent(m)}`} class="tag">{m}</a>
          ))}
        </div>
      </>
    )}

    {crux.length > 0 && (
      <>
        <span class="s-label">Crux</span>
        <div class="s-tags">
          {crux.map(f => (
            <a href={`${base}/browse?crux=${encodeURIComponent(f)}`} class="tag">{f}</a>
          ))}
        </div>
      </>
    )}

    {wordCount > 0 && (
      <>
        <span class="s-label">Words</span>
        <div class="s-value">{wordCount}</div>
      </>
    )}

    {domains.length > 0 && (
      <>
        <span class="s-label">Domain</span>
        <div class="s-tags">
          {domains.map(t => (
            <a href={`${base}/browse?domain=${encodeURIComponent(t)}`} class="tag">{t}</a>
          ))}
        </div>
      </>
    )}

    {ground.length > 0 && (
      <>
        <span class="s-label">Ground</span>
        <div class="s-tags">
          {ground.map(g => (
            <a href={`${base}/browse?ground=${encodeURIComponent(g)}`} class="tag">{g}</a>
          ))}
        </div>
      </>
    )}

    {relatedPoems.length > 0 && (
      <>
        <span class="s-label" style="margin-top:1rem; display:block;">Related poems</span>
        <ul class="related-list">
          {relatedPoems.map(r => (
            <li class="related-item">
              <a href={`${base}/poem/${r.slug}`}>{r.title}</a>
            </li>
          ))}
        </ul>
      </>
    )}

    {nextPoem && (
      <div class="next-poem">
        <span class="next-label">Next poem</span>
        <a href={`${base}/poem/${nextPoem.slug}`} class="next-link">{nextPoem.title}</a>
      </div>
    )}
  </aside>
</div>

<!-- Copy feedback toast -->
<div class="copy-feedback" id="copy-feedback">Link copied to clipboard</div>

<script define:vars={{ slug: poem.slug, title: poem.title, poemUrl }}>
  // Bookmark functionality with Safari localStorage fix
  function getBookmarks() {
    try {
      const data = localStorage.getItem('barking-bookmarks');
      if (!data) return [];
      return JSON.parse(data);
    } catch (e) {
      console.error('Failed to read bookmarks:', e);
      return [];
    }
  }

  function saveBookmarks(bookmarks) {
    try {
      localStorage.setItem('barking-bookmarks', JSON.stringify(bookmarks));
      return true;
    } catch (e) {
      console.error('Failed to save bookmarks:', e);
      return false;
    }
  }

  function isBookmarked(slug) {
    return getBookmarks().includes(slug);
  }

  function toggleBookmark(slug) {
    const bookmarks = getBookmarks();
    const idx = bookmarks.indexOf(slug);
    if (idx > -1) {
      bookmarks.splice(idx, 1);
    } else {
      bookmarks.push(slug);
    }
    saveBookmarks(bookmarks);
    return idx === -1;
  }

  // Initialize bookmark button
  const bookmarkBtn = document.getElementById('bookmark-btn');
  if (bookmarkBtn) {
    const bookmarked = isBookmarked(slug);
    
    if (bookmarked) {
      bookmarkBtn.classList.add('bookmarked');
      bookmarkBtn.querySelector('span').textContent = 'Marked';
      bookmarkBtn.setAttribute('aria-label', 'Remove mark');
    }

    bookmarkBtn.addEventListener('click', function() {
      const nowBookmarked = toggleBookmark(slug);
      this.classList.toggle('bookmarked', nowBookmarked);
      this.querySelector('span').textContent = nowBookmarked ? 'Marked' : 'Mark';
      this.setAttribute('aria-label', nowBookmarked ? 'Remove mark' : 'Mark this poem');
    });
  }

  // Track reading history
  try {
    const history = JSON.parse(localStorage.getItem('barking-history') || '[]');
    const filtered = history.filter(s => s !== slug);
    filtered.unshift(slug);
    localStorage.setItem('barking-history', JSON.stringify(filtered.slice(0, 50)));
  } catch (e) {
    console.error('Failed to save history:', e);
  }

  // Send functionality - dropdown instead of modal
  const shareBtn = document.getElementById('send-btn');
  const shareDropdown = document.getElementById('send-dropdown');
  const copyLinkBtn = document.getElementById('copy-link');
  const emailSend = document.getElementById('email-share');
  const twitterSend = document.getElementById('twitter-share');
  const facebookSend = document.getElementById('facebook-share');
  const whatsappSend = document.getElementById('whatsapp-share');
  const nativeSendBtn = document.getElementById('native-share');
  const copyFeedback = document.getElementById('copy-feedback');

  const shareText = `${title} — a poem from Barking by Anatta Nergui`;
  
  // Email share
  if (emailSend) {
    const emailSubject = encodeURIComponent(shareText);
    const emailBody = encodeURIComponent(`I thought you might enjoy this poem:\n\n${title}\n\n${poemUrl}`);
    emailSend.href = `mailto:?subject=${emailSubject}&body=${emailBody}`;
  }

  // Twitter/X share
  if (twitterSend) {
    const tweetText = encodeURIComponent(`"${title}" — from Barking by Anatta Nergui\n\n${poemUrl}`);
    twitterSend.href = `https://twitter.com/intent/tweet?text=${tweetText}`;
  }

  // Facebook share
  if (facebookSend) {
    facebookSend.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(poemUrl)}`;
  }

  // WhatsApp share
  if (whatsappSend) {
    const waText = encodeURIComponent(`${title} — from Barking by Anatta Nergui\n${poemUrl}`);
    whatsappSend.href = `https://wa.me/?text=${waText}`;
  }

  // Check if native share is available (mobile devices)
  if (nativeSendBtn && navigator.share) {
    nativeSendBtn.style.display = 'flex';
  }

  // Toggle dropdown
  if (shareBtn && shareDropdown) {
    shareBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      shareDropdown.classList.toggle('open');
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!shareDropdown.contains(e.target) && e.target !== shareBtn) {
        shareDropdown.classList.remove('open');
      }
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && shareDropdown.classList.contains('open')) {
        shareDropdown.classList.remove('open');
      }
    });
  }

  // Copy link
  if (copyLinkBtn) {
    copyLinkBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      try {
        await navigator.clipboard.writeText(poemUrl);
        if (copyFeedback) {
          copyFeedback.classList.add('show');
          setTimeout(() => copyFeedback.classList.remove('show'), 2000);
        }
        if (shareDropdown) shareDropdown.classList.remove('open');
      } catch (err) {
        // Fallback for older browsers
        const textArea = document.createElement('textarea');
        textArea.value = poemUrl;
        textArea.style.position = 'fixed';
        textArea.style.left = '-999999px';
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand('copy');
          if (copyFeedback) {
            copyFeedback.classList.add('show');
            setTimeout(() => copyFeedback.classList.remove('show'), 2000);
          }
        } catch (err) {
          console.error('Failed to copy:', err);
        }
        document.body.removeChild(textArea);
        if (shareDropdown) shareDropdown.classList.remove('open');
      }
    });
  }

  // Native share (mobile)
  if (nativeSendBtn) {
    nativeSendBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      try {
        await navigator.share({
          title: shareText,
          text: shareText,
          url: poemUrl
        });
        if (shareDropdown) shareDropdown.classList.remove('open');
      } catch (err) {
        if (err.name !== 'AbortError') {
          console.error('Send failed:', err);
        }
      }
    });
  }

  // Close dropdown when clicking email or twitter links
  if (emailSend) {
    emailSend.addEventListener('click', () => {
      setTimeout(() => {
        if (shareDropdown) shareDropdown.classList.remove('open');
      }, 100);
    });
  }

  if (twitterSend) {
    twitterSend.addEventListener('click', () => {
      setTimeout(() => {
        if (shareDropdown) shareDropdown.classList.remove('open');
      }, 100);
    });
  }

  if (facebookSend) {
    facebookSend.addEventListener('click', () => {
      setTimeout(() => {
        if (shareDropdown) shareDropdown.classList.remove('open');
      }, 100);
    });
  }

  if (whatsappSend) {
    whatsappSend.addEventListener('click', () => {
      setTimeout(() => {
        if (shareDropdown) shareDropdown.classList.remove('open');
      }, 100);
    });
  }
</script>
</Base>
