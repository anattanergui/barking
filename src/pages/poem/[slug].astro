---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getAllPoems, getPoemBySlug, slugify } from '../../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://anattanergui.github.io/barking';

export async function getStaticPaths() {
  const poems = getAllPoems();
  return poems.map((p, i) => ({
    params: { slug: p.slug },
    props: {
      poem: p,
      prevPoem: poems[i - 1] ?? null,
      nextPoem: poems[i + 1] ?? null,
      allPoems: poems,
    },
  }));
}

const { poem, prevPoem, nextPoem, allPoems } = Astro.props;
const { title, atmosphere, crux, domains, ground, related, content, wordCount } = poem;

const description = poem.description || `${title} — a poem from Barking by Anatta Nergui`;

// Word count: check if any other poem shares the same count
const wordCountShared = wordCount > 0 &&
  allPoems.some(p => p.slug !== poem.slug && p.wordCount === wordCount);

// Convert markdown line breaks to HTML stanzas
const stanzas = content.split(/\n{2,}/);
const bodyHtml = stanzas
  .map(s => s.split('\n').filter(l => !l.startsWith('#')).join('\n'))
  .filter(s => s.trim())
  .map(s => `<p>${s.replace(/\n/g, '<br>')}</p>`)
  .join('\n');

// Resolve related slugs (frontmatter may store titles rather than slugs)
const relatedPoems = related
  .map(r => allPoems.find(p => p.slug === slugify(r) || p.title === r))
  .filter(Boolean)
  .slice(0, 6);

// ── JSON-LD schema ────────────────────────────────────────────────────────────
const plainText = content
  .split('\n')
  .filter(l => !l.startsWith('#'))
  .join('\n')
  .trim();

const keywords = [
  ...atmosphere,
  ...crux,
  ...domains,
  ...ground,
  ...(poem.tags || []),
].filter(Boolean).join(', ');

const poemUrl = `${siteUrl}/poem/${poem.slug}/`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Poem',
  name: title,
  description: description,
  text: plainText,
  url: poemUrl,
  author: {
    '@type': 'Person',
    name: 'Anatta Nergui',
    url: siteUrl,
  },
  isPartOf: {
    '@type': 'Book',
    name: 'Barking',
    url: siteUrl,
    author: {
      '@type': 'Person',
      name: 'Anatta Nergui',
    },
  },
  ...(keywords ? { keywords } : {}),
  ...(wordCount > 0 ? { wordCount } : {}),
};
---
<Base {title} {description}>
  <JsonLd slot="head" schema={schema} />

<style>
  .poem-col {
    padding: 5rem 6rem;
    max-width: 680px;
    margin: 0 auto;
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 3.5rem;
    transition: color 0.2s;
  }
  .back:hover { color: var(--ink); }

  .poem-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 4rem;
  }

  .poem-body {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.05rem;
    line-height: 2.3;
    font-weight: 400;
  }
  .poem-body :global(p) { margin-bottom: 1.5rem; }
  .poem-body :global(p:last-child) { margin-bottom: 0; }

  /* ── Action bar ── */
  .poem-actions {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
  }

  .action-btn {
    font-family: 'Karla', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .action-btn:hover { color: var(--ink); }

  .bookmark-btn::before { content: '✒'; font-size: 1rem; line-height: 1; }
  .bookmark-btn.bookmarked { color: var(--ink); }
  .send-btn::before { content: '↗'; font-size: 1rem; line-height: 1; }

  .info-btn::before {
    content: '↓';
    font-size: 1rem;
    line-height: 1;
    display: inline-block;
    transition: transform 0.25s;
  }
  .info-btn.open::before { transform: rotate(180deg); }

  /* ── Send dropdown ── */
  .send-dropdown {
    display: none;
    position: absolute;
    bottom: 100%;
    left: 0;
    margin-bottom: 0.5rem;
    background: var(--bg-panel);
    border: 1px solid var(--rule);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    z-index: 1000;
    min-width: 200px;
  }
  .send-dropdown.open { display: block; }

  .send-option {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.9rem 1.1rem;
    background: none;
    border: none;
    border-bottom: 1px solid var(--rule);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
    text-decoration: none;
    color: var(--ink);
    width: 100%;
    font-family: 'Karla', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .send-option:last-child { border-bottom: none; }
  .send-option:hover { background: var(--stat-hover); }

  .send-icon {
    font-size: 1.1rem;
    line-height: 1;
    width: 20px;
    text-align: center;
    flex-shrink: 0;
  }

  /* ── Info panel (collapsed by default) ── */
  .info-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.3s ease;
  }
  .info-panel.open {
    max-height: 600px;
    opacity: 1;
  }

  .info-inner {
    padding: 1.8rem 0 0.5rem;
    border-top: 1px solid var(--rule);
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.8rem 3rem;
  }

  .info-label {
    font-family: 'Karla', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: 0.5rem;
  }

  .info-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .info-tag {
    display: inline-block;
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--tag-ink);
    background: var(--tag-bg);
    padding: 0.25rem 0.7rem;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .info-tag:hover {
    background: var(--accent);
    color: var(--paper);
  }

  .info-value {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.85rem;
    color: var(--ink);
  }

  /* ── Related poems ── */
  .related-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .related-label {
    font-family: 'Karla', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: 1rem;
  }

  .related-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .related-link {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.82rem;
    color: var(--ink);
    background: var(--tag-bg);
    text-decoration: none;
    padding: 0.35rem 0.85rem;
    display: inline-block;
    line-height: 1.5;
    transition: background 0.15s, color 0.15s;
  }
  .related-link:hover {
    background: var(--accent);
    color: var(--paper);
  }

  /* ── Next poem ── */
  .next-poem {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .next-label {
    font-family: 'Karla', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: 0.6rem;
  }

  .next-link {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--ink);
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.2s;
    display: block;
  }
  .next-link:hover { color: var(--accent); }

  /* ── Copy toast ── */
  .copy-feedback {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--btn-bg);
    color: var(--btn-ink);
    padding: 1rem 1.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    z-index: 3000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .copy-feedback.show { opacity: 1; }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .poem-col { padding: 2.5rem 1.5rem; }
    .poem-title { font-size: 2rem; margin-bottom: 3rem; }
    .poem-body { font-size: 1rem; line-height: 2; }
  }
</style>

<div class="poem-col">
  <a href={`${base}/browse`} class="back">
    <span>←</span>
    <span>Back to collection</span>
  </a>

  <h1 class="poem-title">{title}</h1>

  <div class="poem-body" set:html={bodyHtml} />

  <!-- Action bar: Mark · Send · Info -->
  <div class="poem-actions">
    <button
      class="action-btn bookmark-btn"
      id="bookmark-btn"
      aria-label="Mark this poem"
    >
      <span>Mark</span>
    </button>

    <div style="position: relative;">
      <button
        class="action-btn send-btn"
        id="send-btn"
        aria-label="Share this poem"
      >
        <span>Send</span>
      </button>
      <div class="send-dropdown" id="send-dropdown">
        <button class="send-option" id="copy-link">
          <span class="send-icon">🔗</span>
          <span>Copy Link</span>
        </button>
        <a class="send-option" id="email-share" href="">
          <span class="send-icon">✉️</span>
          <span>Email</span>
        </a>
        <a class="send-option" id="twitter-share" href="" target="_blank" rel="noopener noreferrer">
          <span class="send-icon">𝕏</span>
          <span>Post on X</span>
        </a>
        <a class="send-option" id="facebook-share" href="" target="_blank" rel="noopener noreferrer">
          <span class="send-icon">f</span>
          <span>Facebook</span>
        </a>
        <a class="send-option" id="whatsapp-share" href="" target="_blank" rel="noopener noreferrer">
          <span class="send-icon">💬</span>
          <span>WhatsApp</span>
        </a>
      </div>
    </div>

    <button
      class="action-btn info-btn"
      id="info-btn"
      aria-label="Show poem info"
      aria-expanded="false"
    >
      <span>Info</span>
    </button>
  </div>

  <!-- Collapsed metadata panel -->
  <div class="info-panel" id="info-panel" aria-hidden="true">
    <div class="info-inner">
      {atmosphere.length > 0 && (
        <div class="info-group">
          <span class="info-label">Atmosphere</span>
          <div class="info-tags">
            {atmosphere.map(m => (
              <a href={`${base}/browse?atmosphere=${encodeURIComponent(m)}`} class="info-tag">{m}</a>
            ))}
          </div>
        </div>
      )}
      {crux.length > 0 && (
        <div class="info-group">
          <span class="info-label">Crux</span>
          <div class="info-tags">
            {crux.map(f => (
              <a href={`${base}/browse?crux=${encodeURIComponent(f)}`} class="info-tag">{f}</a>
            ))}
          </div>
        </div>
      )}
      {domains.length > 0 && (
        <div class="info-group">
          <span class="info-label">Domain</span>
          <div class="info-tags">
            {domains.map(t => (
              <a href={`${base}/browse?domain=${encodeURIComponent(t)}`} class="info-tag">{t}</a>
            ))}
          </div>
        </div>
      )}
      {ground.length > 0 && (
        <div class="info-group">
          <span class="info-label">Ground</span>
          <div class="info-tags">
            {ground.map(g => (
              <a href={`${base}/browse?ground=${encodeURIComponent(g)}`} class="info-tag">{g}</a>
            ))}
          </div>
        </div>
      )}
      {wordCount > 0 && (
        <div class="info-group">
          <span class="info-label">Words</span>
          {wordCountShared
            ? <a href={`${base}/length?wc=${wordCount}`} class="info-tag">{wordCount}</a>
            : <div class="info-value">{wordCount}</div>
          }
        </div>
      )}
    </div>
  </div>

  <!-- Related poems — always visible -->
  {relatedPoems.length > 0 && (
    <div class="related-section">
      <span class="related-label">Related poems</span>
      <div class="related-list">
        {relatedPoems.map(r => (
          <a href={`${base}/poem/${r.slug}`} class="related-link">{r.title}</a>
        ))}
      </div>
    </div>
  )}

  <!-- Next poem -->
  {nextPoem && (
    <div class="next-poem">
      <span class="next-label">Next poem</span>
      <a href={`${base}/poem/${nextPoem.slug}`} class="next-link">{nextPoem.title}</a>
    </div>
  )}
</div>

<!-- Copy feedback toast -->
<div class="copy-feedback" id="copy-feedback">Link copied to clipboard</div>

<script define:vars={{ slug: poem.slug, title: poem.title, poemUrl }}>
  // ── Bookmarks ──────────────────────────────────────────────────────────────
  function getBookmarks() {
    try { return JSON.parse(localStorage.getItem('barking-bookmarks') || '[]'); }
    catch (e) { return []; }
  }
  function saveBookmarks(b) {
    try { localStorage.setItem('barking-bookmarks', JSON.stringify(b)); } catch (e) {}
  }
  function toggleBookmark(slug) {
    const b = getBookmarks(), idx = b.indexOf(slug);
    if (idx > -1) b.splice(idx, 1); else b.push(slug);
    saveBookmarks(b);
    return idx === -1;
  }

  const bookmarkBtn = document.getElementById('bookmark-btn');
  if (bookmarkBtn) {
    if (getBookmarks().includes(slug)) {
      bookmarkBtn.classList.add('bookmarked');
      bookmarkBtn.querySelector('span').textContent = 'Marked';
      bookmarkBtn.setAttribute('aria-label', 'Remove mark');
    }
    bookmarkBtn.addEventListener('click', function () {
      const now = toggleBookmark(slug);
      this.classList.toggle('bookmarked', now);
      this.querySelector('span').textContent = now ? 'Marked' : 'Mark';
      this.setAttribute('aria-label', now ? 'Remove mark' : 'Mark this poem');
    });
  }

  // ── Reading history ────────────────────────────────────────────────────────
  try {
    const h = JSON.parse(localStorage.getItem('barking-history') || '[]');
    const f = h.filter(s => s !== slug);
    f.unshift(slug);
    localStorage.setItem('barking-history', JSON.stringify(f.slice(0, 50)));
  } catch (e) {}

  // ── Info panel toggle ──────────────────────────────────────────────────────
  const infoBtn   = document.getElementById('info-btn');
  const infoPanel = document.getElementById('info-panel');

  if (infoBtn && infoPanel) {
    infoBtn.addEventListener('click', () => {
      const isOpen = infoPanel.classList.toggle('open');
      infoBtn.classList.toggle('open', isOpen);
      infoBtn.setAttribute('aria-expanded', String(isOpen));
      infoPanel.setAttribute('aria-hidden', String(!isOpen));
    });
  }

  // ── Send dropdown ──────────────────────────────────────────────────────────
  const shareBtn      = document.getElementById('send-btn');
  const shareDropdown = document.getElementById('send-dropdown');
  const copyLinkBtn   = document.getElementById('copy-link');
  const emailSend     = document.getElementById('email-share');
  const twitterSend   = document.getElementById('twitter-share');
  const facebookSend  = document.getElementById('facebook-share');
  const whatsappSend  = document.getElementById('whatsapp-share');
  const copyFeedback  = document.getElementById('copy-feedback');

  const shareText = `${title} — a poem from Barking by Anatta Nergui`;

  if (emailSend) emailSend.href = `mailto:?subject=${encodeURIComponent(shareText)}&body=${encodeURIComponent(`I thought you might enjoy this poem:\n\n${title}\n\n${poemUrl}`)}`;
  if (twitterSend) twitterSend.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(`"${title}" — from Barking by Anatta Nergui\n\n${poemUrl}`)}`;
  if (facebookSend) facebookSend.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(poemUrl)}`;
  if (whatsappSend) whatsappSend.href = `https://wa.me/?text=${encodeURIComponent(`${title} — from Barking by Anatta Nergui\n${poemUrl}`)}`;

  if (shareBtn && shareDropdown) {
    shareBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      shareDropdown.classList.toggle('open');
    });
    document.addEventListener('click', (e) => {
      if (!shareDropdown.contains(e.target) && e.target !== shareBtn)
        shareDropdown.classList.remove('open');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') shareDropdown.classList.remove('open');
    });
  }

  if (copyLinkBtn) {
    copyLinkBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      try {
        await navigator.clipboard.writeText(poemUrl);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = poemUrl;
        ta.style.cssText = 'position:fixed;left:-999999px';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch {}
        document.body.removeChild(ta);
      }
      if (copyFeedback) {
        copyFeedback.classList.add('show');
        setTimeout(() => copyFeedback.classList.remove('show'), 2000);
      }
      if (shareDropdown) shareDropdown.classList.remove('open');
    });
  }

  [emailSend, twitterSend, facebookSend, whatsappSend].forEach(el => {
    if (el) el.addEventListener('click', () => {
      setTimeout(() => { if (shareDropdown) shareDropdown.classList.remove('open'); }, 100);
    });
  });
</script>
</Base>
