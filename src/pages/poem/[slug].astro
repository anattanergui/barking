---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getAllPoems, getPoemBySlug, slugify } from '../../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://anattanergui.github.io/barking';

export async function getStaticPaths() {
  const poems = getAllPoems();
  return poems.map((p, i) => ({
    params: { slug: p.slug },
    props: {
      poem: p,
      prevPoem: poems[i - 1] ?? null,
      nextPoem: poems[i + 1] ?? null,
      allPoems: poems,
    },
  }));
}

const { poem, prevPoem, nextPoem, allPoems } = Astro.props;
const { title, atmosphere, crux, domains, ground, related, content, wordCount } = poem;

const metaParts = [
  atmosphere.length > 0 ? atmosphere.join(', ') : null,
  crux.length       > 0 ? crux.join(', ')       : null,
  domains.length    > 0 ? domains.join(', ')     : null,
].filter(Boolean);
const generatedDescription = metaParts.length
  ? `${title} — ${metaParts.join(' · ')}`
  : `${title} — a poem`;
const description = poem.description || generatedDescription;

// Convert markdown line breaks to HTML stanzas
const stanzas = content.split(/\n{2,}/);
const bodyHtml = stanzas
  .map(s => s.split('\n').filter(l => !l.startsWith('#')).join('\n'))
  .filter(s => s.trim())
  .map(s => `<p>${s.replace(/\n/g, '<br>')}</p>`)
  .join('\n');

// Resolve related slugs (frontmatter may store titles rather than slugs)
const relatedPoems = related
  .map(r => allPoems.find(p => p.slug === slugify(r) || p.title === r))
  .filter(Boolean)
  .slice(0, 6);

// ── JSON-LD schema ────────────────────────────────────────────────────────────
// Plain text content for the schema (strip markdown headings)
const plainText = content
  .split('\n')
  .filter(l => !l.startsWith('#'))
  .join('\n')
  .trim();

const keywords = [
  ...atmosphere,
  ...crux,
  ...domains,
  ...ground,
  ...(poem.tags || []),
].filter(Boolean).join(', ');

const poemUrl = `${siteUrl}/poem/${poem.slug}/`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Poem',
  name: title,
  description: description,
  text: plainText,
  url: poemUrl,
  author: {
    '@type': 'Person',
    name: 'Anatta Nergui',
    url: siteUrl,
  },
  isPartOf: {
    '@type': 'Book',
    name: 'Barking',
    url: siteUrl,
    author: {
      '@type': 'Person',
      name: 'Anatta Nergui',
    },
  },
  ...(keywords ? { keywords } : {}),
  ...(wordCount > 0 ? { wordCount } : {}),
};
---
<Base {title} {description}>
  <JsonLd slot="head" schema={schema} />

<style>
  .poem-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    min-height: calc(100vh - var(--nav-h));
  }

  /* Reading column */
  .poem-col {
    padding: 5rem 6rem;
    max-width: 680px;
  }

  .back {
    display: inline-flex; 
    align-items: center; 
    gap: 0.4rem;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 3.5rem;
    transition: color 0.2s;
  }
  .back:hover { color: var(--ink); }

  .poem-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 4rem;
  }

  .poem-body {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.05rem;
    line-height: 2.3;
    font-weight: 400;
  }
  .poem-body :global(p) {
    margin-bottom: 1.5rem;
  }
  .poem-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Action buttons after poem content */
  .poem-actions {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .action-btn {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: none;
    border: 1px solid var(--rule);
    cursor: pointer;
    padding: 0.7rem 1.2rem;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .action-btn::before { 
    font-size: 1.15rem; 
    line-height: 1;
  }
  .bookmark-btn::before { 
    content: '✒'; 
  }
  .bookmark-btn.bookmarked {
    color: var(--ink);
    border-color: var(--ink);
  }
  .bookmark-btn.bookmarked::before { 
    content: '✒'; 
  }
  .send-btn::before {
    content: '↗';
  }
  .action-btn:hover { 
    color: var(--ink); 
    border-color: var(--muted);
    background: var(--bg-panel);
  }

  /* Send modal */
  .send-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 2000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    pointer-events: none;
    overflow-y: auto;
  }
  .send-modal.open {
    display: flex;
    pointer-events: auto;
  }

  .send-panel {
    background: var(--bg);
    border: 1px solid var(--rule);
    max-width: 460px;
    width: 100%;
    padding: 2.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    pointer-events: auto;
    margin: auto;
    position: relative;
  }

  .send-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .send-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--ink);
  }

  .send-close {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0.2rem 0.5rem;
    line-height: 1;
    transition: color 0.2s;
  }
  .send-close:hover {
    color: var(--ink);
  }

  .send-options {
    display: grid;
    gap: 0.8rem;
  }

  .send-option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: none;
    border: 1px solid var(--rule);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s, border-color 0.15s;
    text-decoration: none;
    color: var(--ink);
  }
  .send-option:hover {
    background: var(--bg-panel);
    border-color: var(--muted);
  }

  .send-icon {
    font-size: 1.4rem;
    line-height: 1;
    width: 24px;
    text-align: center;
    flex-shrink: 0;
  }

  .send-label {
    flex: 1;
  }

  .send-label-title {
    font-family: 'Karla', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 0.2rem;
  }

  .send-label-desc {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.7rem;
    color: var(--muted);
    font-style: italic;
  }

  .copy-feedback {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--btn-bg);
    color: var(--btn-ink);
    padding: 1rem 1.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    z-index: 3000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .copy-feedback.show {
    opacity: 1;
  }

  /* Sidebar column */
  .sidebar-col {
    background: var(--bg-panel);
    border-left: 1px solid var(--rule);
    padding: 5rem 2.5rem;
    overflow-y: auto;
    max-height: calc(100vh - var(--nav-h));
    position: sticky;
    top: var(--nav-h);
  }

  .s-label {
    display: block;
    font-family: 'Karla', sans-serif;
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.8rem;
    position: relative;
    cursor: help;
  }

  .s-label[data-tooltip]::after {
    content: attr(data-tooltip);
    position: absolute;
    left: 0;
    bottom: calc(100% + 0.5rem);
    background: var(--bg);
    color: var(--ink);
    padding: 0.5rem 0.8rem;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: none;
    white-space: nowrap;
    border: 1px solid var(--rule);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    z-index: 10;
  }
  .s-label[data-tooltip]:hover::after {
    opacity: 1;
  }

  .s-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.8rem;
  }

  .tag {
    display: inline-block;
    font-family: 'Karla', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--tag-ink);
    background: var(--tag-bg);
    padding: 0.3rem 0.8rem;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .tag:hover {
    background: var(--accent);
    color: var(--paper);
  }

  .s-value {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.9rem;
    color: var(--ink);
    margin-bottom: 1.8rem;
  }

  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .related-item {
    margin-bottom: 0;
  }
  .related-item a {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.78rem;
    color: var(--ink);
    background: var(--tag-bg);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    display: inline-block;
    padding: 0.4rem 0.9rem;
    line-height: 1.4;
  }
  .related-item a:hover {
    background: var(--accent);
    color: var(--paper);
  }

  /* Adjacent poem navigation */
  .nav-poem {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .nav-prev,
  .nav-next {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem;
    border: 1px solid var(--rule);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .nav-prev:hover,
  .nav-next:hover {
    background: var(--stat-hover);
    border-color: var(--muted);
  }

  .nav-next {
    text-align: right;
  }

  .nav-label {
    font-family: 'Karla', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .nav-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 300;
    color: var(--ink);
    line-height: 1.3;
  }

  /* Mobile adjustments */
  @media (max-width: 1100px) {
    .poem-layout {
      grid-template-columns: 1fr;
    }

    .sidebar-col {
      position: static;
      max-height: none;
      border-left: none;
      border-top: 1px solid var(--rule);
      padding: 3rem 2rem;
    }

    .poem-col {
      padding: 3rem 2rem;
    }
  }

  @media (max-width: 700px) {
    .poem-col {
      padding: 2.5rem 1.5rem;
    }

    .sidebar-col {
      padding: 2.5rem 1.5rem;
    }

    .poem-title {
      font-size: 2rem;
      margin-bottom: 3rem;
    }

    .poem-body {
      font-size: 1rem;
      line-height: 2;
    }

    .action-btn {
      font-size: 0.6rem;
      padding: 0.6rem 1rem;
    }

    .nav-poem {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
  }
</style>

<div class="poem-layout">
  <div class="poem-col">
    <a href={`${base}/browse`} class="back">
      <span>←</span>
      <span>Back to collection</span>
    </a>

    <h1 class="poem-title">{title}</h1>

    <div class="poem-body" set:html={bodyHtml} />

    <div class="poem-actions">
      <button 
        class="action-btn bookmark-btn" 
        id="bookmark-btn"
        aria-label="Mark this poem"
      >
        <span>Mark</span>
      </button>
      <button 
        class="action-btn send-btn" 
        id="send-btn"
        aria-label="Share this poem"
      >
        <span>Send</span>
      </button>
    </div>
  </div>

  <aside class="sidebar-col">
    {atmosphere.length > 0 && (
      <>
        <span 
          class="s-label"
          data-tooltip="The sensory or emotional tone of the poem"
        >
          Atmosphere
        </span>
        <div class="s-tags">
          {atmosphere.map(m => (
            <a href={`${base}/browse?atmosphere=${encodeURIComponent(m)}`} class="tag">{m}</a>
          ))}
        </div>
      </>
    )}

    {crux.length > 0 && (
      <>
        <span 
          class="s-label"
          data-tooltip="The conceptual pivot or core tension of the poem"
        >
          Crux
        </span>
        <div class="s-tags">
          {crux.map(f => (
            <a href={`${base}/browse?crux=${encodeURIComponent(f)}`} class="tag">{f}</a>
          ))}
        </div>
      </>
    )}

    {wordCount > 0 && (
      <>
        <span class="s-label">Words</span>
        <div class="s-value">{wordCount}</div>
      </>
    )}

    {domains.length > 0 && (
      <>
        <span 
          class="s-label"
          data-tooltip="The subject matter or thematic territory"
        >
          Domain
        </span>
        <div class="s-tags">
          {domains.map(t => (
            <a href={`${base}/browse?domain=${encodeURIComponent(t)}`} class="tag">{t}</a>
          ))}
        </div>
      </>
    )}

    {ground.length > 0 && (
      <>
        <span 
          class="s-label"
          data-tooltip="The philosophical or methodological approach"
        >
          Ground
        </span>
        <div class="s-tags">
          {ground.map(g => (
            <a href={`${base}/browse?ground=${encodeURIComponent(g)}`} class="tag">{g}</a>
          ))}
        </div>
      </>
    )}

    {relatedPoems.length > 0 && (
      <>
        <span class="s-label" style="margin-top:1rem; display:block;">Related poems</span>
        <ul class="related-list">
          {relatedPoems.map(r => (
            <li class="related-item">
              <a href={`${base}/poem/${r.slug}`}>{r.title}</a>
            </li>
          ))}
        </ul>
      </>
    )}

    {(prevPoem || nextPoem) && (
      <nav class="nav-poem" aria-label="Adjacent poems">
        {prevPoem
          ? <a href={`${base}/poem/${prevPoem.slug}`} class="nav-prev">
              <span class="nav-label">← Previous</span>
              <span class="nav-title">{prevPoem.title}</span>
            </a>
          : <span />
        }
        {nextPoem &&
          <a href={`${base}/poem/${nextPoem.slug}`} class="nav-next">
            <span class="nav-title">{nextPoem.title}</span>
          </a>
        }
      </nav>
    )}
  </aside>
</div>

<!-- Send Modal -->
<div class="send-modal" id="send-modal" role="dialog" aria-labelledby="send-title" aria-modal="true">
  <div class="send-panel">
    <div class="send-header">
      <h2 class="send-title" id="send-title">Send</h2>
      <button class="send-close" id="send-close" aria-label="Close share menu">×</button>
    </div>
    <div class="send-options">
      <button class="send-option" id="copy-link" data-action="copy">
        <div class="send-icon">🔗</div>
        <div class="send-label">
          <div class="send-label-title">Copy Link</div>
          <div class="send-label-desc">Copy URL to clipboard</div>
        </div>
      </button>
      <a class="send-option" id="email-share" data-action="email">
        <div class="send-icon">✉️</div>
        <div class="send-label">
          <div class="send-label-title">Email</div>
          <div class="send-label-desc">Send via email</div>
        </div>
      </a>
      <a class="send-option" id="twitter-share" target="_blank" rel="noopener noreferrer">
        <div class="send-icon">𝕏</div>
        <div class="send-label">
          <div class="send-label-title">Post on X</div>
          <div class="send-label-desc">Send on X (Twitter)</div>
        </div>
      </a>
      <button class="send-option" id="native-share" data-action="native" style="display: none;">
        <div class="send-icon">↗</div>
        <div class="send-label">
          <div class="send-label-title">Send...</div>
          <div class="send-label-desc">Use device share menu</div>
        </div>
      </button>
    </div>
  </div>
</div>

<!-- Copy feedback toast -->
<div class="copy-feedback" id="copy-feedback">Link copied to clipboard</div>

<script define:vars={{ slug: poem.slug, title: poem.title, poemUrl }}>
  // Bookmark functionality with Safari localStorage fix
  function getBookmarks() {
    try {
      const data = localStorage.getItem('barking-bookmarks');
      if (!data) return [];
      return JSON.parse(data);
    } catch (e) {
      console.error('Failed to read bookmarks:', e);
      return [];
    }
  }

  function saveBookmarks(bookmarks) {
    try {
      localStorage.setItem('barking-bookmarks', JSON.stringify(bookmarks));
      return true;
    } catch (e) {
      console.error('Failed to save bookmarks:', e);
      return false;
    }
  }

  function isBookmarked(slug) {
    return getBookmarks().includes(slug);
  }

  function toggleBookmark(slug) {
    const bookmarks = getBookmarks();
    const idx = bookmarks.indexOf(slug);
    if (idx > -1) {
      bookmarks.splice(idx, 1);
    } else {
      bookmarks.push(slug);
    }
    saveBookmarks(bookmarks);
    return idx === -1;
  }

  // Initialize bookmark button
  const bookmarkBtn = document.getElementById('bookmark-btn');
  if (bookmarkBtn) {
    const bookmarked = isBookmarked(slug);
    
    if (bookmarked) {
      bookmarkBtn.classList.add('bookmarked');
      bookmarkBtn.querySelector('span').textContent = 'Marked';
      bookmarkBtn.setAttribute('aria-label', 'Remove mark');
    }

    bookmarkBtn.addEventListener('click', function() {
      const nowBookmarked = toggleBookmark(slug);
      this.classList.toggle('bookmarked', nowBookmarked);
      this.querySelector('span').textContent = nowBookmarked ? 'Marked' : 'Mark';
      this.setAttribute('aria-label', nowBookmarked ? 'Remove mark' : 'Mark this poem');
    });
  }

  // Track reading history
  try {
    const history = JSON.parse(localStorage.getItem('barking-history') || '[]');
    const filtered = history.filter(s => s !== slug);
    filtered.unshift(slug);
    localStorage.setItem('barking-history', JSON.stringify(filtered.slice(0, 50)));
  } catch (e) {
    console.error('Failed to save history:', e);
  }

  // Send functionality
  const shareBtn = document.getElementById('send-btn');
  const shareModal = document.getElementById('send-modal');
  const shareClose = document.getElementById('send-close');
  const copyLinkBtn = document.getElementById('copy-link');
  const emailSend = document.getElementById('email-share');
  const twitterSend = document.getElementById('twitter-share');
  const nativeSendBtn = document.getElementById('native-share');
  const copyFeedback = document.getElementById('copy-feedback');

  const shareText = `${title} — a poem from Barking by Anatta Nergui`;
  
  // Email share
  if (emailSend) {
    const emailSubject = encodeURIComponent(shareText);
    const emailBody = encodeURIComponent(`I thought you might enjoy this poem:\n\n${title}\n\n${poemUrl}`);
    emailSend.href = `mailto:?subject=${emailSubject}&body=${emailBody}`;
  }

  // Twitter/X share
  if (twitterSend) {
    const tweetText = encodeURIComponent(`"${title}" — from Barking by Anatta Nergui\n\n${poemUrl}`);
    twitterSend.href = `https://twitter.com/intent/tweet?text=${tweetText}`;
  }

  // Check if native share is available (mobile devices)
  if (nativeSendBtn && navigator.share) {
    nativeSendBtn.style.display = 'flex';
  }

  // Track scroll position for modal
  let scrollPosition = 0;

  // Open modal
  if (shareBtn && shareModal) {
    shareBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      
      // Save current scroll position
      scrollPosition = window.pageYOffset || document.documentElement.scrollTop;
      
      // Prevent body scroll
      document.body.style.overflow = 'hidden';
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollPosition}px`;
      document.body.style.width = '100%';
      
      shareModal.classList.add('open');
      shareModal.scrollTop = 0;
    });
  }

  // Close modal
  function closeModal() {
    if (shareModal) {
      shareModal.classList.remove('open');
      
      // Restore body scroll
      document.body.style.overflow = '';
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      
      // Restore scroll position
      window.scrollTo(0, scrollPosition);
    }
  }

  if (shareClose) {
    shareClose.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      closeModal();
    });
  }
  
  if (shareModal) {
    shareModal.addEventListener('click', (e) => {
      if (e.target === shareModal) {
        closeModal();
      }
    });
  }

  // Escape key closes modal
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && shareModal && shareModal.classList.contains('open')) {
      closeModal();
    }
  });

  // Copy link
  if (copyLinkBtn) {
    copyLinkBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      try {
        await navigator.clipboard.writeText(poemUrl);
        if (copyFeedback) {
          copyFeedback.classList.add('show');
          setTimeout(() => copyFeedback.classList.remove('show'), 2000);
        }
      } catch (err) {
        // Fallback for older browsers
        const textArea = document.createElement('textarea');
        textArea.value = poemUrl;
        textArea.style.position = 'fixed';
        textArea.style.left = '-999999px';
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand('copy');
          if (copyFeedback) {
            copyFeedback.classList.add('show');
            setTimeout(() => copyFeedback.classList.remove('show'), 2000);
          }
        } catch (err) {
          console.error('Failed to copy:', err);
        }
        document.body.removeChild(textArea);
      }
    });
  }

  // Native share (mobile)
  if (nativeSendBtn) {
    nativeSendBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      try {
        await navigator.share({
          title: shareText,
          text: shareText,
          url: poemUrl
        });
        closeModal();
      } catch (err) {
        if (err.name !== 'AbortError') {
          console.error('Send failed:', err);
        }
      }
    });
  }
</script>
</Base>
