---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getAllPoems, getPoemBySlug, slugify } from '../../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://anattanergui.github.io/barking';

export async function getStaticPaths() {
  const poems = getAllPoems();
  return poems.map((p, i) => ({
    params: { slug: p.slug },
    props: {
      poem: p,
      prevPoem: poems[i - 1] ?? null,
      nextPoem: poems[i + 1] ?? null,
      allPoems: poems,
    },
  }));
}

const { poem, prevPoem, nextPoem, allPoems } = Astro.props;
const { title, atmosphere, crux, domains, ground, related, content, wordCount } = poem;

const metaParts = [
  atmosphere.length > 0 ? atmosphere.join(', ') : null,
  crux.length       > 0 ? crux.join(', ')       : null,
  domains.length    > 0 ? domains.join(', ')     : null,
].filter(Boolean);
const generatedDescription = metaParts.length
  ? `${title} — ${metaParts.join(' · ')}`
  : `${title} — a poem`;
const description = poem.description || generatedDescription;

// Convert markdown line breaks to HTML stanzas
const stanzas = content.split(/\n{2,}/);
const bodyHtml = stanzas
  .map(s => s.split('\n').filter(l => !l.startsWith('#')).join('\n'))
  .filter(s => s.trim())
  .map(s => `<p>${s.replace(/\n/g, '<br>')}</p>`)
  .join('\n');

// Resolve related slugs (frontmatter may store titles rather than slugs)
const relatedPoems = related
  .map(r => allPoems.find(p => p.slug === slugify(r) || p.title === r))
  .filter(Boolean)
  .slice(0, 6);

// ── JSON-LD schema ────────────────────────────────────────────────────────────
// Plain text content for the schema (strip markdown headings)
const plainText = content
  .split('\n')
  .filter(l => !l.startsWith('#'))
  .join('\n')
  .trim();

const keywords = [
  ...atmosphere,
  ...crux,
  ...domains,
  ...ground,
  ...(poem.tags || []),
].filter(Boolean).join(', ');

const poemUrl = `${siteUrl}/poem/${poem.slug}/`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Poem',
  name: title,
  description: description,
  text: plainText,
  url: poemUrl,
  author: {
    '@type': 'Person',
    name: 'Anatta Nergui',
    url: siteUrl,
  },
  isPartOf: {
    '@type': 'Book',
    name: 'Barking',
    url: siteUrl,
    author: {
      '@type': 'Person',
      name: 'Anatta Nergui',
    },
  },
  ...(keywords ? { keywords } : {}),
  ...(wordCount > 0 ? { wordCount } : {}),
};
---
<Base {title} {description}>
  <JsonLd slot="head" schema={schema} />

<style>
  .poem-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    min-height: calc(100vh - var(--nav-h));
  }

  /* Reading column */
  .poem-col {
    padding: 5rem 6rem;
    max-width: 680px;
  }

  .back {
    display: inline-flex; 
    align-items: center; 
    gap: 0.4rem;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 3.5rem;
    transition: color 0.2s;
  }
  .back:hover { color: var(--ink); }

  .poem-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 4rem;
  }

  .poem-body {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.05rem;
    line-height: 2.3;
    font-weight: 400;
  }
  .poem-body :global(p) {
    margin-bottom: 1.5rem;
  }
  .poem-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Action buttons after poem content */
  .poem-actions {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .action-btn {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: none;
    border: 1px solid var(--rule);
    cursor: pointer;
    padding: 0.7rem 1.2rem;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .action-btn::before { 
    font-size: 1.15rem; 
    line-height: 1;
  }
  .bookmark-btn::before { 
    content: '♡'; 
  }
  .bookmark-btn.bookmarked {
    color: var(--ink);
    border-color: var(--ink);
  }
  .bookmark-btn.bookmarked::before { 
    content: '♥'; 
  }
  .share-btn::before {
    content: '↗';
  }
  .action-btn:hover { 
    color: var(--ink); 
    border-color: var(--muted);
    background: var(--bg-panel);
  }

  /* Share modal */
  .share-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 2000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .share-modal.open {
    display: flex;
  }

  .share-panel {
    background: var(--bg);
    border: 1px solid var(--rule);
    max-width: 460px;
    width: 100%;
    padding: 2.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .share-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .share-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--ink);
  }

  .share-close {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0.2rem 0.5rem;
    line-height: 1;
    transition: color 0.2s;
  }
  .share-close:hover {
    color: var(--ink);
  }

  .share-options {
    display: grid;
    gap: 0.8rem;
  }

  .share-option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: none;
    border: 1px solid var(--rule);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s, border-color 0.15s;
    text-decoration: none;
    color: var(--ink);
  }
  .share-option:hover {
    background: var(--bg-panel);
    border-color: var(--muted);
  }

  .share-icon {
    font-size: 1.4rem;
    line-height: 1;
    width: 24px;
    text-align: center;
    flex-shrink: 0;
  }

  .share-label {
    flex: 1;
  }

  .share-label-title {
    font-family: 'Karla', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 0.2rem;
  }

  .share-label-desc {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.7rem;
    color: var(--muted);
    font-style: italic;
  }

  .copy-feedback {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--ink);
    color: var(--bg);
    padding: 0.8rem 1.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-radius: 4px;
    z-index: 3000;
    display: none;
  }
  .copy-feedback.show {
    display: block;
    animation: fadeInOut 2s ease;
  }

  @keyframes fadeInOut {
    0% { opacity: 0; transform: translateX(-50%) translateY(10px); }
    15% { opacity: 1; transform: translateX(-50%) translateY(0); }
    85% { opacity: 1; transform: translateX(-50%) translateY(0); }
    100% { opacity: 0; transform: translateX(-50%) translateY(10px); }
  }

  /* Sidebar */
  .sidebar {
    border-left: 1px solid var(--rule);
    padding: 5rem 2rem 5rem 2.5rem;
    background: var(--paper-warm);
    position: sticky;
    top: var(--nav-h);
    height: calc(100vh - var(--nav-h));
    overflow-y: auto;
  }

  .s-label {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.6rem;
    display: block;
  }
  
  .s-label[data-tooltip] {
    position: relative;
    cursor: help;
    border-bottom: 1px dotted var(--muted);
    display: inline-block;
  }

  .s-label[data-tooltip]:hover::after {
    content: attr(data-tooltip);
    position: absolute;
    left: 0;
    top: calc(100% + 0.5rem);
    background: var(--bg-panel);
    border: 1px solid var(--rule);
    padding: 0.6rem 0.8rem;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: none;
    color: var(--ink);
    white-space: normal;
    width: 220px;
    z-index: 100;
    line-height: 1.6;
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
  }

  .s-value {
    font-size: 0.85rem;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  .s-tags {
    display: flex; 
    flex-wrap: wrap; 
    gap: 0.35rem;
    margin-bottom: 2rem;
  }

  .related-list { 
    list-style: none; 
    margin-bottom: 2rem; 
  }
  .related-item { 
    border-bottom: 1px solid var(--rule); 
  }
  .related-item:first-child { 
    border-top: 1px solid var(--rule); 
  }
  .related-item a {
    display: block;
    padding: 0.6rem 0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 300;
    transition: color 0.15s, padding-left 0.15s;
    text-decoration: none;
    color: var(--ink);
  }
  .related-item a:hover { 
    color: var(--accent); 
    padding-left: 0.4rem; 
  }

  /* Prev / next navigation */
  .nav-poem {
    display: flex;
    justify-content: space-between;
    padding-top: 1.5rem;
    margin-top: 1.5rem;
    border-top: 1px solid var(--rule);
    gap: 1rem;
  }
  .nav-poem a {
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
    max-width: 45%;
  }
  .nav-poem a:hover { color: var(--ink); }
  .nav-poem .nav-next { 
    text-align: right; 
    margin-left: auto; 
  }
  .nav-poem .nav-label {
    display: block;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--muted);
    margin-bottom: 0.3rem;
    opacity: 0.6;
  }
  .nav-poem .nav-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.9rem;
    font-weight: 300;
    letter-spacing: 0;
    text-transform: none;
    display: block;
    color: var(--ink);
  }

  @media (max-width: 900px) {
    .poem-layout { 
      grid-template-columns: 1fr; 
    }
    .sidebar { 
      position: static; 
      height: auto; 
      border-left: none; 
      border-top: 1px solid var(--rule); 
    }
    .poem-col { 
      padding: 3rem 2rem; 
    }
  }

  @media (max-width: 500px) {
    .poem-col {
      padding: 2rem 1.5rem;
    }
    .sidebar {
      padding: 2rem 1.5rem;
    }
    .poem-title {
      font-size: 1.8rem;
      margin-bottom: 2.5rem;
    }
    .poem-body {
      font-size: 0.95rem;
      line-height: 2.1;
    }
    .share-panel {
      padding: 2rem 1.5rem;
    }
    .poem-actions {
      flex-wrap: wrap;
    }
    .action-btn {
      flex: 1;
      min-width: 120px;
      justify-content: center;
    }
  }
</style>

<div class="poem-layout">
  <article class="poem-col">
    <a href={`${base}/browse`} class="back">← Collection</a>
    <h1 class="poem-title">{title}</h1>
    <div class="poem-body" set:html={bodyHtml} />
    
    <!-- Action buttons after poem content -->
    <div class="poem-actions">
      <button 
        class="action-btn bookmark-btn" 
        id="bookmark-btn" 
        data-slug={poem.slug}
        aria-label="Bookmark this poem"
      >
        <span>Save</span>
      </button>
      <button 
        class="action-btn share-btn"
        id="share-btn"
        aria-label="Share this poem"
      >
        <span>Share</span>
      </button>
    </div>
  </article>

  <aside class="sidebar">
    {atmosphere.length > 0 && (
      <>
        <span 
          class="s-label" 
          data-tooltip="The tonal quality or emotional texture of the poem"
        >
          Atmosphere
        </span>
        <div class="s-tags">
          {atmosphere.map(m => (
            <a href={`${base}/browse?atmosphere=${encodeURIComponent(m)}`} class="tag">{m}</a>
          ))}
        </div>
      </>
    )}

    {crux.length > 0 && (
      <>
        <span 
          class="s-label"
          data-tooltip="The conceptual pivot or core tension of the poem"
        >
          Crux
        </span>
        <div class="s-tags">
          {crux.map(f => (
            <a href={`${base}/browse?crux=${encodeURIComponent(f)}`} class="tag">{f}</a>
          ))}
        </div>
      </>
    )}

    {wordCount > 0 && (
      <>
        <span class="s-label">Words</span>
        <div class="s-value">{wordCount}</div>
      </>
    )}

    {domains.length > 0 && (
      <>
        <span 
          class="s-label"
          data-tooltip="The subject matter or thematic territory"
        >
          Domain
        </span>
        <div class="s-tags">
          {domains.map(t => (
            <a href={`${base}/browse?domain=${encodeURIComponent(t)}`} class="tag">{t}</a>
          ))}
        </div>
      </>
    )}

    {ground.length > 0 && (
      <>
        <span 
          class="s-label"
          data-tooltip="The philosophical or methodological approach"
        >
          Ground
        </span>
        <div class="s-tags">
          {ground.map(g => (
            <a href={`${base}/browse?ground=${encodeURIComponent(g)}`} class="tag">{g}</a>
          ))}
        </div>
      </>
    )}

    {relatedPoems.length > 0 && (
      <>
        <span class="s-label" style="margin-top:1rem; display:block;">Related poems</span>
        <ul class="related-list">
          {relatedPoems.map(r => (
            <li class="related-item">
              <a href={`${base}/poem/${r.slug}`}>{r.title}</a>
            </li>
          ))}
        </ul>
      </>
    )}

    {(prevPoem || nextPoem) && (
      <nav class="nav-poem" aria-label="Adjacent poems">
        {prevPoem
          ? <a href={`${base}/poem/${prevPoem.slug}`} class="nav-prev">
              <span class="nav-label">← Previous</span>
              <span class="nav-title">{prevPoem.title}</span>
            </a>
          : <span />
        }
        {nextPoem &&
          <a href={`${base}/poem/${nextPoem.slug}`} class="nav-next">
            <span class="nav-label">Next →</span>
            <span class="nav-title">{nextPoem.title}</span>
          </a>
        }
      </nav>
    )}
  </aside>
</div>

<!-- Share Modal -->
<div class="share-modal" id="share-modal" role="dialog" aria-labelledby="share-title" aria-modal="true">
  <div class="share-panel">
    <div class="share-header">
      <h2 class="share-title" id="share-title">Share</h2>
      <button class="share-close" id="share-close" aria-label="Close share menu">×</button>
    </div>
    <div class="share-options">
      <button class="share-option" id="copy-link" data-action="copy">
        <div class="share-icon">🔗</div>
        <div class="share-label">
          <div class="share-label-title">Copy Link</div>
          <div class="share-label-desc">Copy URL to clipboard</div>
        </div>
      </button>
      <a class="share-option" id="email-share" data-action="email">
        <div class="share-icon">✉️</div>
        <div class="share-label">
          <div class="share-label-title">Email</div>
          <div class="share-label-desc">Send via email</div>
        </div>
      </a>
      <a class="share-option" id="twitter-share" target="_blank" rel="noopener noreferrer">
        <div class="share-icon">𝕏</div>
        <div class="share-label">
          <div class="share-label-title">Post on X</div>
          <div class="share-label-desc">Share on X (Twitter)</div>
        </div>
      </a>
      <button class="share-option" id="native-share" data-action="native" style="display: none;">
        <div class="share-icon">↗</div>
        <div class="share-label">
          <div class="share-label-title">Share...</div>
          <div class="share-label-desc">Use device share menu</div>
        </div>
      </button>
    </div>
  </div>
</div>

<!-- Copy feedback toast -->
<div class="copy-feedback" id="copy-feedback">Link copied to clipboard</div>

<script define:vars={{ slug: poem.slug, title: poem.title, poemUrl }}>
  // Bookmark functionality with Safari localStorage fix
  function getBookmarks() {
    try {
      const data = localStorage.getItem('barking-bookmarks');
      if (!data) return [];
      return JSON.parse(data);
    } catch (e) {
      console.error('Failed to read bookmarks:', e);
      return [];
    }
  }

  function saveBookmarks(bookmarks) {
    try {
      localStorage.setItem('barking-bookmarks', JSON.stringify(bookmarks));
      return true;
    } catch (e) {
      console.error('Failed to save bookmarks:', e);
      return false;
    }
  }

  function isBookmarked(slug) {
    return getBookmarks().includes(slug);
  }

  function toggleBookmark(slug) {
    const bookmarks = getBookmarks();
    const idx = bookmarks.indexOf(slug);
    if (idx > -1) {
      bookmarks.splice(idx, 1);
    } else {
      bookmarks.push(slug);
    }
    saveBookmarks(bookmarks);
    return idx === -1;
  }

  // Initialize bookmark button
  const bookmarkBtn = document.getElementById('bookmark-btn');
  if (bookmarkBtn) {
    const bookmarked = isBookmarked(slug);
    
    if (bookmarked) {
      bookmarkBtn.classList.add('bookmarked');
      bookmarkBtn.querySelector('span').textContent = 'Saved';
      bookmarkBtn.setAttribute('aria-label', 'Remove bookmark');
    }

    bookmarkBtn.addEventListener('click', function() {
      const nowBookmarked = toggleBookmark(slug);
      this.classList.toggle('bookmarked', nowBookmarked);
      this.querySelector('span').textContent = nowBookmarked ? 'Saved' : 'Save';
      this.setAttribute('aria-label', nowBookmarked ? 'Remove bookmark' : 'Bookmark this poem');
    });
  }

  // Track reading history
  try {
    const history = JSON.parse(localStorage.getItem('barking-history') || '[]');
    const filtered = history.filter(s => s !== slug);
    filtered.unshift(slug);
    localStorage.setItem('barking-history', JSON.stringify(filtered.slice(0, 50)));
  } catch (e) {
    console.error('Failed to save history:', e);
  }

  // Share functionality
  const shareBtn = document.getElementById('share-btn');
  const shareModal = document.getElementById('share-modal');
  const shareClose = document.getElementById('share-close');
  const copyLinkBtn = document.getElementById('copy-link');
  const emailShare = document.getElementById('email-share');
  const twitterShare = document.getElementById('twitter-share');
  const nativeShareBtn = document.getElementById('native-share');
  const copyFeedback = document.getElementById('copy-feedback');

  const shareText = `${title} — a poem from Barking by Anatta Nergui`;
  
  // Email share
  const emailSubject = encodeURIComponent(shareText);
  const emailBody = encodeURIComponent(`I thought you might enjoy this poem:\n\n${title}\n\n${poemUrl}`);
  emailShare.href = `mailto:?subject=${emailSubject}&body=${emailBody}`;

  // Twitter/X share
  const tweetText = encodeURIComponent(`"${title}" — from Barking by Anatta Nergui\n\n${poemUrl}`);
  twitterShare.href = `https://twitter.com/intent/tweet?text=${tweetText}`;

  // Check if native share is available (mobile devices)
  if (navigator.share) {
    nativeShareBtn.style.display = 'flex';
  }

  // Open modal
  shareBtn.addEventListener('click', () => {
    shareModal.classList.add('open');
    document.body.style.overflow = 'hidden';
  });

  // Close modal
  function closeModal() {
    shareModal.classList.remove('open');
    document.body.style.overflow = '';
  }

  shareClose.addEventListener('click', closeModal);
  shareModal.addEventListener('click', (e) => {
    if (e.target === shareModal) closeModal();
  });

  // Escape key closes modal
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && shareModal.classList.contains('open')) {
      closeModal();
    }
  });

  // Copy link
  copyLinkBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(poemUrl);
      copyFeedback.classList.add('show');
      setTimeout(() => copyFeedback.classList.remove('show'), 2000);
    } catch (err) {
      // Fallback for older browsers
      const textArea = document.createElement('textarea');
      textArea.value = poemUrl;
      textArea.style.position = 'fixed';
      textArea.style.left = '-999999px';
      document.body.appendChild(textArea);
      textArea.select();
      try {
        document.execCommand('copy');
        copyFeedback.classList.add('show');
        setTimeout(() => copyFeedback.classList.remove('show'), 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
      document.body.removeChild(textArea);
    }
  });

  // Native share (mobile)
  if (nativeShareBtn) {
    nativeShareBtn.addEventListener('click', async () => {
      try {
        await navigator.share({
          title: shareText,
          text: shareText,
          url: poemUrl
        });
        closeModal();
      } catch (err) {
        if (err.name !== 'AbortError') {
          console.error('Share failed:', err);
        }
      }
    });
  }
</script>
</Base>
