---
// src/pages/lexicon.astro
import Base from '../layouts/Base.astro';
import { getAllPoemsMeta } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const poems = getAllPoemsMeta();

// Note: internal key is 'domains' but browse query param is 'domain'
const categories = [
  { key: 'domains',    label: 'domain',     param: 'domain' },
  { key: 'atmosphere', label: 'atmosphere', param: 'atmosphere' },
  { key: 'ground',     label: 'ground',     param: 'ground' },
  { key: 'crux',       label: 'crux',       param: 'crux' },
];

const taxonomy = {};
for (const { key } of categories) taxonomy[key] = {};

for (const poem of poems) {
  for (const { key } of categories) {
    const terms = poem[key] || [];
    for (const term of terms) {
      if (!taxonomy[key][term]) taxonomy[key][term] = [];
      taxonomy[key][term].push({ title: poem.title, slug: poem.slug });
    }
  }
}

for (const { key } of categories) {
  taxonomy[key] = Object.fromEntries(
    Object.entries(taxonomy[key]).sort(([a], [b]) => a.localeCompare(b))
  );
}
---

<Base title="Lexicon">
  <style>
    .page-header {
      padding: 3.5rem 3rem 2rem;
    }

    .page-header h1 {
      font-size: 2.2rem;
      font-weight: 400;
      letter-spacing: 0.02em;
      color: var(--ink);
      margin-bottom: 0.3rem;
    }

    .page-header .subtitle {
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .lex-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--rule);
      margin: 0 3rem 5rem;
    }

    @media (max-width: 768px) {
      .lex-grid { grid-template-columns: 1fr; margin: 0 1.5rem 3rem; }
      .page-header { padding: 2.5rem 1.5rem 1.5rem; }
    }

    .cat-block {
      background: var(--bg);
      padding: 2.5rem;
    }

    .cat-title {
      font-size: 0.63rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 1.8rem;
      padding-bottom: 0.7rem;
      border-bottom: 1px solid var(--rule);
    }

    .cat-title.domains    { color: #7a9bc9; border-color: #7a9bc9; }
    .cat-title.atmosphere { color: #c97a9b; border-color: #c97a9b; }
    .cat-title.ground     { color: #7ac99b; border-color: #7ac99b; }
    .cat-title.crux       { color: #c9b97a; border-color: #c9b97a; }

    .term-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--rule);
      cursor: pointer;
      transition: all 0.15s;
    }

    .term-row:hover {
      padding-left: 0.5rem;
      background: var(--bg-panel);
    }

    .term-row:hover .term-name { color: var(--ink); }

    .term-name {
      font-size: 0.88rem;
      color: var(--muted);
      letter-spacing: 0.03em;
      transition: color 0.15s;
    }

    .term-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .term-count {
      font-size: 0.63rem;
      color: var(--muted);
      letter-spacing: 0.1em;
    }

    /* Link to browse with filter pre-applied */
    .browse-link {
      font-size: 0.55rem;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.1em;
      opacity: 0;
      transition: opacity 0.15s;
      border: 1px solid var(--rule);
      padding: 0.15rem 0.4rem;
    }

    .term-row:hover .browse-link { opacity: 1; }
    .browse-link:hover { color: var(--ink); border-color: var(--ink); }

    .chevron {
      font-size: 0.45rem;
      color: var(--muted);
      margin-left: 0.3rem;
      display: inline-block;
      transition: transform 0.2s;
    }

    .term-row.open .chevron { transform: rotate(90deg); }

    .poem-list {
      display: none;
      flex-direction: column;
      gap: 0.3rem;
      padding: 0.6rem 0 0.8rem 0.8rem;
      background: var(--bg-panel);
    }

    .poem-list.open { display: flex; }

    .poem-list a {
      font-size: 0.78rem;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.03em;
      font-style: italic;
      transition: color 0.15s;
    }

    .poem-list a:hover { color: var(--ink); }
  </style>

  <div class="page-header">
    <h1>Lexicon</h1>
    <p class="subtitle">All terms — by category</p>
  </div>

  <div class="lex-grid">
    {categories.map(({ key, label, param }) => (
      <div class="cat-block">
        <div class={`cat-title ${key}`}>{label}</div>
        {Object.entries(taxonomy[key]).map(([term, termPoems]) => (
          <div>
            <div class="term-row" data-key={key} data-term={term}>
              <span class="term-name">{term}</span>
              <span class="term-meta">
                <a
                  class="browse-link"
                  href={`${base}/browse?${param}=${encodeURIComponent(term)}`}
                  title="Filter in Browse"
                  onclick="event.stopPropagation()"
                >browse</a>
                <span class="term-count">{termPoems.length}</span>
                <span class="chevron">▶</span>
              </span>
            </div>
            <div class="poem-list" id={`poems-${key}-${term.replace(/\s+/g, '-')}`}>
              {termPoems.map(p => (
                <a href={`${base}/poem/${p.slug}`}>{p.title}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>

  <script>
    document.querySelectorAll('.term-row').forEach(row => {
      row.addEventListener('click', () => {
        const key  = row.dataset.key;
        const term = row.dataset.term.replace(/\s+/g, '-');
        const list = document.getElementById(`poems-${key}-${term}`);
        if (!list) return;
        const isOpen = list.classList.contains('open');
        list.classList.toggle('open', !isOpen);
        row.classList.toggle('open', !isOpen);
      });
    });
  </script>
</Base>
