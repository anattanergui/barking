---
// src/pages/lexicon.astro
import { getAllPoemsMeta } from '../lib/poems.js';

const poems = getAllPoemsMeta();

const categories = [
  { key: 'domains',    label: 'domain' },
  { key: 'atmosphere', label: 'atmosphere' },
  { key: 'ground',     label: 'ground' },
  { key: 'crux',       label: 'crux' },
];

// Build map: category -> term -> [{ title, slug }]
const taxonomy = {};
for (const { key } of categories) {
  taxonomy[key] = {};
}

for (const poem of poems) {
  for (const { key } of categories) {
    const terms = poem[key] || [];
    for (const term of terms) {
      if (!taxonomy[key][term]) taxonomy[key][term] = [];
      taxonomy[key][term].push({ title: poem.title, slug: poem.slug });
    }
  }
}

// Sort terms alphabetically
for (const { key } of categories) {
  taxonomy[key] = Object.fromEntries(
    Object.entries(taxonomy[key]).sort(([a], [b]) => a.localeCompare(b))
  );
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lexicon — Anatta Nergui</title>
  <style>
    :root {
      --bg: #0e0e0e;
      --surface: #161616;
      --border: #2a2a2a;
      --text: #d4cfc8;
      --muted: #6b6560;
      --domains: #7a9bc9;
      --atmosphere: #c97a9b;
      --ground: #7ac99b;
      --crux: #c9b97a;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Georgia', 'Times New Roman', serif;
      min-height: 100vh;
    }

    header {
      padding: 2.5rem 3rem 1.5rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .site-name {
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
    }

    nav { display: flex; gap: 2rem; }

    nav a {
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    nav a:hover, nav a.active { color: var(--text); }

    .page-header { padding: 4rem 3rem 2rem; }

    h1 {
      font-size: 2.5rem;
      font-weight: 400;
      letter-spacing: 0.02em;
      margin-bottom: 0.4rem;
    }

    .subtitle {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--border);
      margin: 0 3rem 4rem;
    }

    @media (max-width: 768px) {
      .grid { grid-template-columns: 1fr; margin: 0 1.5rem 3rem; }
      header { padding: 1.5rem; flex-direction: column; gap: 1rem; }
      .page-header { padding: 2.5rem 1.5rem 1.5rem; }
    }

    .category-block {
      background: var(--bg);
      padding: 2.5rem;
    }

    .category-title {
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 2rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border);
    }

    .category-title.domains    { color: var(--domains);    border-color: var(--domains); }
    .category-title.atmosphere { color: var(--atmosphere); border-color: var(--atmosphere); }
    .category-title.ground     { color: var(--ground);     border-color: var(--ground); }
    .category-title.crux       { color: var(--crux);       border-color: var(--crux); }

    .term-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.55rem 0;
      border-bottom: 1px solid #1c1c1c;
      cursor: pointer;
      transition: all 0.15s;
    }

    .term-row:hover { background: var(--surface); padding-left: 0.5rem; }
    .term-row:hover .term-name { color: var(--text); }

    .term-name {
      font-size: 0.9rem;
      color: #a09a93;
      letter-spacing: 0.03em;
      transition: color 0.15s;
    }

    .term-count {
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.1em;
    }

    .chevron {
      font-size: 0.5rem;
      color: var(--muted);
      margin-left: 0.5rem;
      display: inline-block;
      transition: transform 0.2s;
    }

    .term-row.open .chevron { transform: rotate(90deg); }

    .poem-list {
      display: none;
      flex-direction: column;
      gap: 0.3rem;
      padding: 0.6rem 0 0.8rem 0.8rem;
      background: var(--surface);
    }

    .poem-list.open { display: flex; }

    .poem-list a {
      font-size: 0.78rem;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.04em;
      font-style: italic;
      transition: color 0.15s;
    }

    .poem-list a:hover { color: var(--text); }
  </style>
</head>
<body>

  <header>
    <a href="/" class="site-name">Anatta Nergui</a>
    <nav>
      <a href="/">Home</a>
      <a href="/browse">Browse</a>
      <a href="/graph">Graph</a>
      <a href="/lexicon" class="active">Lexicon</a>
      <a href="/cloud">Cloud</a>
      <a href="/about">About</a>
    </nav>
  </header>

  <div class="page-header">
    <h1>Lexicon</h1>
    <p class="subtitle">All terms — by category</p>
  </div>

  <div class="grid">
    {categories.map(({ key, label }) => (
      <div class="category-block">
        <div class={`category-title ${key}`}>{label}</div>
        <div class="term-list">
          {Object.entries(taxonomy[key]).map(([term, termPoems]) => (
            <div>
              <div class="term-row" data-key={key} data-term={term}>
                <span class="term-name">{term}</span>
                <span>
                  <span class="term-count">{termPoems.length}</span>
                  <span class="chevron">▶</span>
                </span>
              </div>
              <div class="poem-list" id={`poems-${key}-${term.replace(/\s+/g, '-')}`}>
                {termPoems.map(p => (
                  <a href={`/poems/${p.slug}`}>{p.title}</a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <script>
    document.querySelectorAll('.term-row').forEach(row => {
      row.addEventListener('click', () => {
        const key  = row.dataset.key;
        const term = row.dataset.term.replace(/\s+/g, '-');
        const list = document.getElementById(`poems-${key}-${term}`);
        if (!list) return;
        const isOpen = list.classList.contains('open');
        list.classList.toggle('open', !isOpen);
        row.classList.toggle('open', !isOpen);
      });
    });
  </script>

</body>
</html>
