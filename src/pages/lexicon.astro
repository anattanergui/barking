---
// src/pages/lexicon.astro
import Base from '../layouts/Base.astro';
import { getAllPoemsMeta } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const poems = getAllPoemsMeta();

const categories = [
  { key: 'domains',    label: 'domain'     },
  { key: 'atmosphere', label: 'atmosphere' },
  { key: 'ground',     label: 'ground'     },
  { key: 'crux',       label: 'crux'       },
];

const taxonomyRaw = {};
for (const { key } of categories) taxonomyRaw[key] = {};

for (const poem of poems) {
  for (const { key } of categories) {
    for (const term of (poem[key] || [])) {
      if (!taxonomyRaw[key][term]) taxonomyRaw[key][term] = [];
      taxonomyRaw[key][term].push({ title: poem.title, slug: poem.slug });
    }
  }
}

const taxonomyArrays = {};
for (const { key } of categories) {
  taxonomyArrays[key] = Object.entries(taxonomyRaw[key])
    .map(([term, termPoems]) => ({ term, poems: termPoems }))
    .sort((a, b) => a.term.localeCompare(b.term));
}

const taxonomyB64 = Buffer.from(JSON.stringify(taxonomyArrays)).toString('base64');
---

<Base title="Lexicon">

  <!--
    IMPORTANT: All styles that apply to dynamically-injected HTML (term-row,
    poem-list, etc.) must use is:global. Astro scopes component <style> tags
    with a hash, but innerHTML elements don't receive that hash, so scoped
    rules never match them.

    Static elements (page-header, lex-grid, cat-block, cat-header, controls)
    can stay scoped.
  -->

  <style>
    .page-header {
      padding: 3.5rem 3rem 2rem;
    }
    .page-header h1 {
      font-size: 2.2rem;
      font-weight: 400;
      letter-spacing: 0.02em;
      color: var(--ink);
      margin-bottom: 0.3rem;
    }
    .page-header .subtitle {
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* ── Search bar ─────────────────────────────────────────────────────── */
    .lex-search-wrap {
      padding: 0 3rem 2.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .lex-search-inner {
      position: relative;
      flex: 1;
      max-width: 38rem;
    }
    .lex-search-inner svg.search-icon {
      position: absolute;
      left: 0.85rem;
      top: 50%;
      transform: translateY(-50%);
      width: 13px;
      height: 13px;
      color: var(--muted);
      pointer-events: none;
      transition: color 0.15s;
    }
    #lex-search {
      width: 100%;
      background: var(--search-bg);
      border: 1px solid var(--search-border);
      color: var(--ink);
      font-family: 'Karla', sans-serif;
      font-size: 0.82rem;
      letter-spacing: 0.04em;
      padding: 0.55rem 2.2rem 0.55rem 2.4rem;
      outline: none;
      transition: border-color 0.15s;
      box-sizing: border-box;
    }
    #lex-search::placeholder {
      color: var(--muted);
      opacity: 0.7;
    }
    #lex-search:focus {
      border-color: var(--muted);
    }
    #lex-search:focus + .search-clear,
    .search-clear.visible {
      opacity: 1;
      pointer-events: auto;
    }
    .search-clear {
      position: absolute;
      right: 0.75rem;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      padding: 0.1rem 0.2rem;
      font-size: 0.75rem;
      opacity: 0;
      pointer-events: none;
      transition: color 0.15s, opacity 0.15s;
      line-height: 1;
    }
    .search-clear:hover { color: var(--ink); }

    /* hint text beside the search bar */
    .lex-search-hint {
      font-size: 0.6rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      white-space: nowrap;
      opacity: 0;
      transition: opacity 0.2s;
    }
    .lex-search-hint.visible { opacity: 1; }

    /* ── Grid ────────────────────────────────────────────────────────────── */
    .lex-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--rule);
      margin: 0 3rem 5rem;
    }
    @media (max-width: 768px) {
      .lex-grid        { grid-template-columns: 1fr; margin: 0 1.5rem 3rem; }
      .page-header     { padding: 2.5rem 1.5rem 1.5rem; }
      .lex-search-wrap { padding: 0 1.5rem 2rem; }
    }

    .cat-block {
      background: var(--bg);
      padding: 2.5rem 2.5rem 0;
    }
    .cat-block.collapsed {
      padding-bottom: 2.5rem;
    }

    .cat-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.8rem;
      padding-bottom: 0.7rem;
    }
    .cat-header.domains    { border-bottom: 1px solid #7a9bc9; }
    .cat-header.atmosphere { border-bottom: 1px solid #c97a9b; }
    .cat-header.ground     { border-bottom: 1px solid #7ac99b; }
    .cat-header.crux       { border-bottom: 1px solid #c9b97a; }

    /* Left side of header: title + live term count */
    .cat-header-left {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
      flex-shrink: 0;
      min-width: 0;
    }
    .cat-title {
      font-size: 0.63rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin: 0;
      flex-shrink: 0;
    }
    .cat-title.domains    { color: #7a9bc9; }
    .cat-title.atmosphere { color: #c97a9b; }
    .cat-title.ground     { color: #7ac99b; }
    .cat-title.crux       { color: #c9b97a; }

    /* "3 of 214" counter shown during search */
    .cat-count {
      font-size: 0.55rem;
      letter-spacing: 0.12em;
      color: var(--muted);
      white-space: nowrap;
      opacity: 0;
      transition: opacity 0.2s;
    }
    .cat-count.visible { opacity: 1; }

    .cat-controls {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      flex-shrink: 0;
    }
    .sort-btn {
      font-family: 'Karla', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: var(--muted);
      background: none;
      border: 1px solid var(--rule);
      padding: 0.2rem 0.55rem;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
      line-height: 1.7;
      white-space: nowrap;
    }
    .sort-btn:hover  { color: var(--ink); border-color: var(--muted); }
    .sort-btn.active { color: var(--ink); border-color: var(--ink); }

    .ctrl-divider {
      width: 1px;
      height: 1rem;
      background: var(--rule);
      flex-shrink: 0;
    }
    .collapse-btn {
      color: var(--muted);
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.15rem 0.25rem;
      transition: color 0.15s;
      line-height: 1;
      display: flex;
      align-items: center;
    }
    .collapse-btn:hover { color: var(--ink); }
    .collapse-btn .arrow {
      display: inline-block;
      font-size: 0.55rem;
      transition: transform 0.2s;
    }
    .cat-block.collapsed .collapse-btn .arrow { transform: rotate(-90deg); }

    .term-list {
      padding-bottom: 2.5rem;
    }
    .cat-block.collapsed .term-list { display: none; }
  </style>

  <!-- Global styles for dynamically-injected innerHTML elements -->
  <style is:global>
    .lex-term-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--rule);
      cursor: pointer;
      transition: padding 0.12s, background 0.12s;
    }
    .lex-term-row:hover { padding-left: 0.5rem; background: var(--bg-panel); }
    .lex-term-row:hover .lex-term-name { color: var(--ink); }

    /* Hidden during search filter */
    .lex-term-row.lex-hidden,
    .lex-term-row.lex-hidden + .lex-poem-list {
      display: none !important;
    }

    .lex-term-name {
      font-size: 0.88rem;
      color: var(--muted);
      letter-spacing: 0.03em;
      transition: color 0.15s;
    }
    /* Highlighted matched substring */
    .lex-term-name mark {
      background: none;
      color: var(--ink);
      font-weight: 600;
    }

    .lex-term-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-shrink: 0;
    }

    /* Cross-category badge: "also in: atmosphere · crux" */
    .lex-also {
      font-size: 0.5rem;
      letter-spacing: 0.1em;
      color: var(--muted);
      opacity: 0;
      transition: opacity 0.15s;
      white-space: nowrap;
    }
    .lex-term-row:hover .lex-also,
    .lex-also.lex-also-search { opacity: 1; }

    .lex-term-count {
      font-size: 0.63rem;
      color: var(--muted);
      letter-spacing: 0.1em;
    }
    .lex-browse-link {
      font-size: 0.55rem;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.1em;
      opacity: 0;
      transition: opacity 0.15s;
      border: 1px solid var(--rule);
      padding: 0.15rem 0.4rem;
    }
    .lex-term-row:hover .lex-browse-link { opacity: 1; }
    .lex-browse-link:hover { color: var(--ink); border-color: var(--ink); }

    .lex-chevron {
      font-size: 0.45rem;
      color: var(--muted);
      margin-left: 0.3rem;
      display: inline-block;
      transition: transform 0.2s;
    }
    .lex-term-row.open .lex-chevron { transform: rotate(90deg); }

    /* Poem sub-list */
    .lex-poem-list {
      display: none;
      flex-direction: column;
      gap: 0.3rem;
      padding: 0.6rem 0 0.8rem 0.8rem;
      background: var(--bg-panel);
    }
    .lex-poem-list.open { display: flex; }
    .lex-poem-list a {
      font-size: 0.78rem;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.03em;
      font-style: italic;
      transition: color 0.15s;
      display: block;
    }
    .lex-poem-list a:hover { color: var(--ink); }

    /* "No results" message per category */
    .lex-no-results {
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.08em;
      padding: 1.2rem 0 0.8rem;
      opacity: 0.6;
      display: none;
    }
    .lex-no-results.visible { display: block; }
  </style>

  <div class="page-header">
    <h1>Lexicon</h1>
    <p class="subtitle">All terms — by category</p>
  </div>

  <!-- Search bar -->
  <div class="lex-search-wrap">
    <div class="lex-search-inner">
      <!-- search icon -->
      <svg class="search-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <circle cx="6.5" cy="6.5" r="4.5"/>
        <line x1="10" y1="10" x2="14" y2="14"/>
      </svg>
      <input
        id="lex-search"
        type="search"
        autocomplete="off"
        spellcheck="false"
        placeholder="search terms across all categories…"
        aria-label="Search lexicon terms"
      />
      <button class="search-clear" id="lex-clear" aria-label="Clear search" title="Clear">✕</button>
    </div>
    <span class="lex-search-hint" id="lex-hint">searching all categories</span>
  </div>

  <div id="lex-data" data-taxonomy={taxonomyB64} data-base={base} hidden></div>

  <div class="lex-grid">
    {categories.map(({ key, label }) => (
      <div class="cat-block" id={`block-${key}`} data-key={key}>
        <div class={`cat-header ${key}`}>
          <div class="cat-header-left">
            <span class={`cat-title ${key}`}>{label}</span>
            <span class="cat-count" id={`count-${key}`}></span>
          </div>
          <div class="cat-controls">
            <button class="sort-btn active" data-key={key} data-sort="alpha">A–Z</button>
            <button class="sort-btn"        data-key={key} data-sort="freq">most used</button>
            <div class="ctrl-divider"></div>
            <button class="collapse-btn" data-key={key} title="Collapse / expand">
              <span class="arrow">▾</span>
            </button>
          </div>
        </div>
        <div class="term-list" id={`list-${key}`}></div>
      </div>
    ))}
  </div>

  <script>
    const dataEl   = document.getElementById('lex-data');
    const base     = dataEl.dataset.base;
    const taxonomy = JSON.parse(atob(dataEl.dataset.taxonomy));

    // Build a flat map: term → [categories it appears in]
    // Used for cross-category "also in:" badges.
    const termCategories = {};
    for (const [cat, terms] of Object.entries(taxonomy)) {
      for (const { term } of terms) {
        if (!termCategories[term]) termCategories[term] = [];
        termCategories[term].push(cat);
      }
    }

    const state = {};
    for (const key of Object.keys(taxonomy)) {
      state[key] = { sort: 'alpha', collapsed: false };
    }

    let currentQuery = '';

    function esc(str) {
      return String(str)
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // Wrap matched substring in <mark> for highlighting.
    function highlight(term, query) {
      if (!query) return esc(term);
      const idx = term.toLowerCase().indexOf(query.toLowerCase());
      if (idx === -1) return esc(term);
      return (
        esc(term.slice(0, idx)) +
        '<mark>' + esc(term.slice(idx, idx + query.length)) + '</mark>' +
        esc(term.slice(idx + query.length))
      );
    }

    function renderList(key) {
      const container = document.getElementById(`list-${key}`);
      if (!container) return;

      const terms = [...taxonomy[key]];
      if (state[key].sort === 'alpha') {
        terms.sort((a, b) => a.term.localeCompare(b.term));
      } else {
        terms.sort((a, b) =>
          b.poems.length - a.poems.length || a.term.localeCompare(b.term)
        );
      }

      container.innerHTML = terms.map(({ term, poems }) => {
        const safeId = `${key}-${term.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}`;

        // Cross-category badge: other categories this term also appears in
        const otherCats = (termCategories[term] || []).filter(c => c !== key);
        const alsoHtml  = otherCats.length > 0
          ? `<span class="lex-also">also in: ${otherCats.map(esc).join(' · ')}</span>`
          : '';

        const poemLinks = poems
          .map(p => `<a href="${base}/poem/${esc(p.slug)}">${esc(p.title)}</a>`)
          .join('\n');

        return `<div>
  <div class="lex-term-row" data-id="${safeId}" data-term="${esc(term)}">
    <span class="lex-term-name">${highlight(term, currentQuery)}</span>
    <span class="lex-term-meta">
      ${alsoHtml}
      <a class="lex-browse-link"
         href="${base}/browse?term=${encodeURIComponent(term)}&cats=${key}"
         title="Filter in Browse"
         onclick="event.stopPropagation()">browse</a>
      <span class="lex-term-count">${poems.length}</span>
      <span class="lex-chevron">▶</span>
    </span>
  </div>
  <div class="lex-poem-list" id="poems-${safeId}">${poemLinks}</div>
</div>`;
      }).join('');

      container.querySelectorAll('.lex-term-row').forEach(row => {
        row.addEventListener('click', () => {
          const list = document.getElementById(`poems-${row.dataset.id}`);
          if (!list) return;
          list.classList.toggle('open');
          row.classList.toggle('open');
        });
      });

      // Ensure no-results placeholder exists
      let noRes = container.querySelector('.lex-no-results');
      if (!noRes) {
        noRes = document.createElement('p');
        noRes.className = 'lex-no-results';
        noRes.textContent = 'no matching terms';
        container.appendChild(noRes);
      }

      // Apply current filter
      applyFilter(key);
    }

    // Filter visible rows in one category and update its count badge.
    function applyFilter(key) {
      const container  = document.getElementById(`list-${key}`);
      const countEl    = document.getElementById(`count-${key}`);
      if (!container) return;

      const q     = currentQuery.toLowerCase();
      const rows  = container.querySelectorAll('.lex-term-row');
      const noRes = container.querySelector('.lex-no-results');
      let visible = 0;

      rows.forEach(row => {
        const term    = row.dataset.term || '';
        const matches = !q || term.toLowerCase().includes(q);
        row.classList.toggle('lex-hidden', !matches);

        // Update highlight in term name
        const nameEl = row.querySelector('.lex-term-name');
        if (nameEl) nameEl.innerHTML = highlight(term, currentQuery);

        // Show "also in" badge whenever search is active
        const alsoEl = row.querySelector('.lex-also');
        if (alsoEl) alsoEl.classList.toggle('lex-also-search', !!q);

        if (matches) visible++;
      });

      // Count badge
      const total = rows.length;
      if (q && countEl) {
        countEl.textContent = `${visible} of ${total}`;
        countEl.classList.toggle('visible', true);
      } else if (countEl) {
        countEl.classList.remove('visible');
      }

      // No-results message
      if (noRes) noRes.classList.toggle('visible', q !== '' && visible === 0);
    }

    // ── Search input handling ──────────────────────────────────────────────

    const searchInput = document.getElementById('lex-search');
    const clearBtn    = document.getElementById('lex-clear');
    const hintEl      = document.getElementById('lex-hint');

    function runSearch(q) {
      currentQuery = q.trim();
      const active = currentQuery.length > 0;

      // Update hint + clear button visibility
      hintEl.classList.toggle('visible', active);
      clearBtn.classList.toggle('visible', active);

      // Re-render all lists so highlights update, then filter
      for (const key of Object.keys(taxonomy)) {
        renderList(key);
      }
    }

    searchInput.addEventListener('input', () => runSearch(searchInput.value));

    searchInput.addEventListener('keydown', e => {
      if (e.key === 'Escape') clearSearch();
    });

    clearBtn.addEventListener('click', clearSearch);

    function clearSearch() {
      searchInput.value = '';
      runSearch('');
      searchInput.focus();
    }

    // ── Sort buttons ───────────────────────────────────────────────────────

    document.querySelectorAll('.sort-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const key  = btn.dataset.key;
        const sort = btn.dataset.sort;
        if (state[key].sort === sort) return;
        state[key].sort = sort;
        document.querySelectorAll(`.sort-btn[data-key="${key}"]`).forEach(b => {
          b.classList.toggle('active', b.dataset.sort === sort);
        });
        const container = document.getElementById(`list-${key}`);
        container?.querySelectorAll('.lex-poem-list.open, .lex-term-row.open')
          .forEach(el => el.classList.remove('open'));
        renderList(key);
      });
    });

    // ── Collapse buttons ───────────────────────────────────────────────────

    document.querySelectorAll('.collapse-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const key   = btn.dataset.key;
        const block = document.getElementById(`block-${key}`);
        state[key].collapsed = !state[key].collapsed;
        block.classList.toggle('collapsed', state[key].collapsed);
      });
    });

    // ── Initial render ─────────────────────────────────────────────────────

    for (const key of Object.keys(taxonomy)) renderList(key);
  </script>
</Base>
