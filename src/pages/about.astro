---
import Base from '../layouts/Base.astro';
import { getAllPoemsMeta } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Only need poem count — use the lightweight meta loader, not full content
const poems = getAllPoemsMeta();
---
<Base
  title="About"
  description="About Barking — a poetry collection by Anatta Nergui"
>
<style>
  .about {
    max-width: 560px;
    margin: 0 auto;
    padding: 7rem 2rem 5rem;
  }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    font-weight: 300;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }
  h1 em { font-style: italic; color: var(--muted); }

  .subtitle {
    font-family: 'Karla', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 2.2;
    margin-bottom: 3rem;
  }

  p {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.95rem;
    line-height: 2.1;
    color: var(--ink);
    margin-bottom: 1.8rem;
  }

  .meta {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 2.5;
  }

  .meta a {
    color: inherit;
    transition: color 0.2s;
  }
  .meta a:hover { color: var(--ink); }
</style>

<div class="about">
  <h1>About <em>Barking</em></h1>
  <p class="subtitle">
    poems, rants, reflections, excavations, confessions,
    self-flagellations, polemics, and all that doesn't get said - all at once
  </p>

  <p>
    Barking was conceived as the title of a book — for this collection. 
  </p>
  <p
    These pages present that book in digital form.
  </p>

  <p
    Age rating: 18 +. 
Call your healthcare provider if you're in trouble.
  </p>

  <div class="meta">
    Anatta Nergui<br>
    {poems.length} poems<br>
    <a href={`${base}/browse`}>Browse the collection →</a>
  </div>
</div>
</Base>
