---
// src/pages/cloud.astro
import { getAllPoemsMeta } from '../lib/poems.js';

const poems = getAllPoemsMeta();

const categories = [
  { key: 'domains',    label: 'domain' },
  { key: 'atmosphere', label: 'atmosphere' },
  { key: 'ground',     label: 'ground' },
  { key: 'crux',       label: 'crux' },
];

// Collect all terms with counts and category
const termMap = {};

for (const poem of poems) {
  for (const { key } of categories) {
    const terms = poem[key] || [];
    for (const term of terms) {
      if (!termMap[term]) termMap[term] = { count: 0, key };
      termMap[term].count++;
    }
  }
}

const allTerms = Object.entries(termMap)
  .map(([term, { count, key }]) => ({ term, count, key }))
  .sort((a, b) => b.count - a.count);

const maxCount = Math.max(...allTerms.map(t => t.count));
const minCount = Math.min(...allTerms.map(t => t.count));
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cloud — Anatta Nergui</title>
  <style>
    :root {
      --bg: #0e0e0e;
      --surface: #161616;
      --border: #2a2a2a;
      --text: #d4cfc8;
      --muted: #6b6560;
      --domains: #7a9bc9;
      --atmosphere: #c97a9b;
      --ground: #7ac99b;
      --crux: #c9b97a;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Georgia', 'Times New Roman', serif;
      min-height: 100vh;
    }

    header {
      padding: 2.5rem 3rem 1.5rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .site-name {
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
    }

    nav { display: flex; gap: 2rem; }

    nav a {
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    nav a:hover, nav a.active { color: var(--text); }

    .page-header {
      padding: 4rem 3rem 1rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 400;
      letter-spacing: 0.02em;
      margin-bottom: 0.4rem;
    }

    .subtitle {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .legend {
      display: flex;
      gap: 1.5rem;
      padding-bottom: 0.4rem;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .legend-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
    }

    .legend-dot.domains    { background: var(--domains); }
    .legend-dot.atmosphere { background: var(--atmosphere); }
    .legend-dot.ground     { background: var(--ground); }
    .legend-dot.crux       { background: var(--crux); }

    .filter-bar {
      padding: 1.5rem 3rem;
      display: flex;
      gap: 0.75rem;
      border-bottom: 1px solid var(--border);
    }

    .filter-btn {
      font-family: 'Georgia', serif;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0.35rem 0.9rem;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.2s;
    }

    .filter-btn:hover           { border-color: var(--text);        color: var(--text); }
    .filter-btn.active-all      { border-color: var(--text);        color: var(--text); }
    .filter-btn.active-domains  { border-color: var(--domains);     color: var(--domains); }
    .filter-btn.active-atmosphere { border-color: var(--atmosphere); color: var(--atmosphere); }
    .filter-btn.active-ground   { border-color: var(--ground);      color: var(--ground); }
    .filter-btn.active-crux     { border-color: var(--crux);        color: var(--crux); }

    .cloud-container {
      padding: 3rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem 1.4rem;
      align-items: center;
      line-height: 2;
    }

    .cloud-term {
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: opacity 0.2s, transform 0.15s;
    }

    .cloud-term:hover { transform: translateY(-2px); opacity: 1 !important; }

    .cloud-term.domains    { color: var(--domains); }
    .cloud-term.atmosphere { color: var(--atmosphere); }
    .cloud-term.ground     { color: var(--ground); }
    .cloud-term.crux       { color: var(--crux); }

    .tooltip {
      position: fixed;
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 0.5rem 0.9rem;
      font-size: 0.7rem;
      letter-spacing: 0.05em;
      color: var(--muted);
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s;
      z-index: 100;
      white-space: nowrap;
    }

    .tooltip.visible { opacity: 1; }

    @media (max-width: 768px) {
      header { padding: 1.5rem; flex-direction: column; gap: 1rem; }
      .page-header { padding: 2.5rem 1.5rem 1rem; flex-direction: column; gap: 1.5rem; align-items: flex-start; }
      .filter-bar { padding: 1.5rem; flex-wrap: wrap; }
      .cloud-container { padding: 2rem 1.5rem; }
    }
  </style>
</head>
<body>

  <header>
    <a href="/" class="site-name">Anatta Nergui</a>
    <nav>
      <a href="/">Home</a>
      <a href="/browse">Browse</a>
      <a href="/graph">Graph</a>
      <a href="/lexicon">Lexicon</a>
      <a href="/cloud" class="active">Cloud</a>
      <a href="/about">About</a>
    </nav>
  </header>

  <div class="page-header">
    <div>
      <h1>Cloud</h1>
      <p class="subtitle">Terms by frequency</p>
    </div>
    <div class="legend">
      {categories.map(({ key, label }) => (
        <div class="legend-item">
          <div class={`legend-dot ${key}`}></div>
          {label}
        </div>
      ))}
    </div>
  </div>

  <div class="filter-bar">
    <button class="filter-btn active-all" data-filter="all">All</button>
    {categories.map(({ key, label }) => (
      <button class="filter-btn" data-filter={key}>{label}</button>
    ))}
  </div>

  <div class="cloud-container">
    {allTerms.map(({ term, count, key }) => {
      const ratio = maxCount === minCount ? 0.5 : (count - minCount) / (maxCount - minCount);
      const size  = (0.8 + ratio * 1.6).toFixed(2);
      return (
        <a
          href={`/lexicon`}
          class={`cloud-term ${key}`}
          data-category={key}
          data-count={count}
          data-term={term}
          style={`font-size: ${size}rem;`}
        >
          {term}
        </a>
      );
    })}
  </div>

  <div class="tooltip" id="tooltip"></div>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const terms   = document.querySelectorAll('.cloud-term');
    const tooltip = document.getElementById('tooltip');

    // Filter
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        buttons.forEach(b => { b.className = 'filter-btn'; });
        btn.classList.add(filter === 'all' ? 'active-all' : `active-${filter}`);

        terms.forEach(term => {
          const match = filter === 'all' || term.dataset.category === filter;
          term.style.opacity = match ? '1' : '0.12';
          term.style.pointerEvents = match ? 'auto' : 'none';
        });
      });
    });

    // Tooltip
    terms.forEach(term => {
      term.addEventListener('mouseenter', () => {
        const count = term.dataset.count;
        const cat   = term.dataset.category;
        tooltip.textContent = `${count} poem${count != 1 ? 's' : ''} · ${cat}`;
        tooltip.classList.add('visible');
      });

      term.addEventListener('mousemove', e => {
        tooltip.style.left = (e.clientX + 14) + 'px';
        tooltip.style.top  = (e.clientY - 28) + 'px';
      });

      term.addEventListener('mouseleave', () => {
        tooltip.classList.remove('visible');
      });
    });
  </script>

</body>
</html>
