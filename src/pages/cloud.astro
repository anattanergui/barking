---
// src/pages/cloud.astro
import Base from '../layouts/Base.astro';
import { getAllPoemsMeta } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const poems = getAllPoemsMeta();

// param = the query string key browse.astro expects
const categories = [
  { key: 'domains',    label: 'domain',     param: 'domain' },
  { key: 'atmosphere', label: 'atmosphere', param: 'atmosphere' },
  { key: 'ground',     label: 'ground',     param: 'ground' },
  { key: 'crux',       label: 'crux',       param: 'crux' },
];

// Build termMap: totalCount across ALL categories, plus per-category breakdown
const termMap = {};

for (const poem of poems) {
  for (const { key } of categories) {
    const terms = poem[key] || [];
    for (const term of terms) {
      if (!termMap[term]) {
        termMap[term] = { totalCount: 0, cats: {} };
      }
      termMap[term].totalCount++;
      termMap[term].cats[key] = (termMap[term].cats[key] || 0) + 1;
    }
  }
}

// Derive dominant category (for colour) from whichever has the most occurrences
const allTerms = Object.entries(termMap)
  .map(([term, { totalCount, cats }]) => {
    const [dominantKey] = Object.entries(cats).sort((a, b) => b[1] - a[1])[0];
    return { term, count: totalCount, key: dominantKey, cats };
  })
  .sort((a, b) => b.count - a.count);

const maxCount = Math.max(...allTerms.map(t => t.count));
const minCount = Math.min(...allTerms.map(t => t.count));
---

<Base title="Cloud">
  <style>
    .page-header {
      padding: 3.5rem 3rem 1rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .page-header h1 {
      font-size: 2.2rem;
      font-weight: 400;
      letter-spacing: 0.02em;
      color: var(--ink);
      margin-bottom: 0.3rem;
    }

    .page-header .subtitle {
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .legend {
      display: flex;
      gap: 1.5rem;
      padding-bottom: 0.3rem;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.63rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .legend-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .legend-dot.domains    { background: #7a9bc9; }
    .legend-dot.atmosphere { background: #c97a9b; }
    .legend-dot.ground     { background: #7ac99b; }
    .legend-dot.crux       { background: #c9b97a; }

    .filter-bar {
      padding: 1.5rem 3rem;
      display: flex;
      gap: 0.75rem;
      border-bottom: 1px solid var(--rule);
      border-top: 1px solid var(--rule);
      margin-top: 1.5rem;
    }

    .filter-btn {
      font-family: 'Georgia', serif;
      font-size: 0.63rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0.3rem 0.85rem;
      border: 1px solid var(--rule);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.2s;
    }

    .filter-btn:hover             { border-color: var(--ink);  color: var(--ink); }
    .filter-btn.active-all        { border-color: var(--ink);  color: var(--ink); }
    .filter-btn.active-domains    { border-color: #7a9bc9; color: #7a9bc9; }
    .filter-btn.active-atmosphere { border-color: #c97a9b; color: #c97a9b; }
    .filter-btn.active-ground     { border-color: #7ac99b; color: #7ac99b; }
    .filter-btn.active-crux       { border-color: #c9b97a; color: #c9b97a; }

    .cloud-container {
      padding: 3rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1.3rem;
      align-items: center;
      line-height: 2;
    }

    /* Each term links directly to browse pre-filtered */
    .cloud-term {
      text-decoration: none;
      display: inline-block;
      transition: opacity 0.2s, transform 0.15s;
    }

    .cloud-term:hover { transform: translateY(-2px); opacity: 1 !important; }

    .cloud-term.domains    { color: #7a9bc9; }
    .cloud-term.atmosphere { color: #c97a9b; }
    .cloud-term.ground     { color: #7ac99b; }
    .cloud-term.crux       { color: #c9b97a; }

    .tooltip {
      position: fixed;
      background: var(--bg-panel);
      border: 1px solid var(--rule);
      padding: 0.5rem 0.9rem;
      font-size: 0.68rem;
      letter-spacing: 0.05em;
      color: var(--muted);
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s;
      z-index: 100;
      white-space: nowrap;
    }

    .tooltip.visible { opacity: 1; }

    @media (max-width: 768px) {
      .page-header { padding: 2.5rem 1.5rem 1rem; flex-direction: column; gap: 1.5rem; align-items: flex-start; }
      .filter-bar  { padding: 1.5rem; flex-wrap: wrap; }
      .cloud-container { padding: 2rem 1.5rem; }
      .legend { flex-wrap: wrap; gap: 1rem; }
    }
  </style>

  <div class="page-header">
    <div>
      <h1>Cloud</h1>
      <p class="subtitle">Terms by frequency — click any term to browse poems</p>
    </div>
    <div class="legend">
      {categories.map(({ key, label }) => (
        <div class="legend-item">
          <div class={`legend-dot ${key}`}></div>
          {label}
        </div>
      ))}
    </div>
  </div>

  <div class="filter-bar">
    <button class="filter-btn active-all" data-filter="all">All</button>
    {categories.map(({ key, label }) => (
      <button class="filter-btn" data-filter={key}>{label}</button>
    ))}
  </div>

  <div class="cloud-container">
    {allTerms.map(({ term, count, key, cats }) => {
      const ratio = maxCount === minCount ? 0.5 : (count - minCount) / (maxCount - minCount);
      const size  = (0.8 + ratio * 1.6).toFixed(2);
      // Encode which categories this term belongs to, so browse can filter across all of them
      const catsParam = encodeURIComponent(Object.keys(cats).join(','));
      return (
        <a
          href={`${base}/browse?term=${encodeURIComponent(term)}&cats=${catsParam}`}
          class={`cloud-term ${key}`}
          data-category={key}
          data-count={count}
          data-term={term}
          style={`font-size: ${size}rem;`}
        >
          {term}
        </a>
      );
    })}
  </div>

  <div class="tooltip" id="tooltip"></div>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const terms   = document.querySelectorAll('.cloud-term');
    const tooltip = document.getElementById('tooltip');

    function applyFilter(filter) {
      buttons.forEach(b => { b.className = 'filter-btn'; });
      const btn = [...buttons].find(b => b.dataset.filter === filter) || buttons[0];
      btn.classList.add(filter === 'all' ? 'active-all' : `active-${filter}`);
      terms.forEach(term => {
        const match = filter === 'all' || term.dataset.category === filter;
        term.style.opacity       = match ? '1' : '0.12';
        term.style.pointerEvents = match ? 'auto' : 'none';
      });
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => applyFilter(btn.dataset.filter));
    });

    // Activate filter from URL hash (e.g. /cloud#atmosphere from home page stats)
    const hash = location.hash.replace('#', '');
    if (hash) applyFilter(hash);

    terms.forEach(term => {
      term.addEventListener('mouseenter', () => {
        const count = term.dataset.count;
        const cat   = term.dataset.category;
        tooltip.textContent = `${count} poem${count != 1 ? 's' : ''} · ${cat}`;
        tooltip.classList.add('visible');
      });
      term.addEventListener('mousemove', e => {
        tooltip.style.left = (e.clientX + 14) + 'px';
        tooltip.style.top  = (e.clientY - 28) + 'px';
      });
      term.addEventListener('mouseleave', () => {
        tooltip.classList.remove('visible');
      });
    });
  </script>
</Base>
