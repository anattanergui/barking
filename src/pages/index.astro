---
import Base from '../layouts/Base.astro';
import { getAllPoems, getAllPoemsMeta, getFilterOptions } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://anattanergui.github.io/barking';

const poems = getAllPoemsMeta();
const filters = getFilterOptions(poems);
const total = poems.length;
const domainCount    = filters.domains.length;
const atmosphereCount = filters.atmospheres.length;
const cruxCount      = filters.cruxes.length;
const groundCount    = filters.grounds ? filters.grounds.length : 0;

// Search index: meta only, no content — keeps the client bundle lean.
const searchIndex = poems.map(p => ({
  slug:       p.slug,
  title:      p.title,
  tags:       p.tags,
  domains:    p.domains,
  atmosphere: p.atmosphere,
  crux:       p.crux,
  preview:    p.preview,
  wordCount:  p.wordCount,
}));

// Featured pool: short poems only.
// Use frontmatter word-count if set, otherwise count from content.
// Criteria: fewer than 60 words AND fewer than 15 non-blank lines.
function contentStats(content) {
  const lines = content
    .split('\n')
    .filter(l => l.trim() && !l.startsWith('#')); // non-blank, non-heading
  const words = content
    .replace(/#+[^\n]*/g, '')   // strip headings
    .trim()
    .split(/\s+/)
    .filter(Boolean).length;
  return { lines: lines.length, words };
}

const featuredPool = getAllPoems()
  .filter(p => {
    // Trust frontmatter wordCount if present and non-zero
    const wc = p.wordCount && p.wordCount > 0
      ? p.wordCount
      : contentStats(p.content).words;
    const { lines } = contentStats(p.content);
    return wc > 0 && wc < 60 && lines < 15;
  })
  .map(p => ({ slug: p.slug, title: p.title, tags: p.tags, content: p.content }));

// Fallback: if no poems pass the filter yet, use all poems (showing preview as content)
const featuredPoolFinal = featuredPool.length > 0
  ? featuredPool
  : searchIndex.map(p => ({ slug: p.slug, title: p.title, tags: p.tags, content: p.preview }));
---

<Base title="Barking">
<style is:global>
  /* ─── LAYOUT ────────────────────────────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - var(--nav-h, 56px));
    border-bottom: 1px solid var(--rule);
  }

  .hero-left {
    padding: 5rem 4rem 4rem 5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-right: 1px solid var(--rule);
  }

  .hero-right {
    padding: 5rem 5rem 4rem 4rem;
    display: flex;
    flex-direction: column;
    background: var(--bg-panel);
    transition: background 0.3s;
  }

  /* ─── LEFT: TYPOGRAPHY ──────────────────────────────────────── */
  .hero-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(4rem, 6vw, 7rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }

  .hero-byline {
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 2rem;
    line-height: 2;
  }

  .hero-desc {
    margin-top: 1.8rem;
    max-width: 380px;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.05rem;
    line-height: 2;
    color: var(--muted);
    font-style: italic;
  }

  /* ─── SEARCH ────────────────────────────────────────────────── */
  .search-wrap {
    margin-top: 2.5rem;
    position: relative;
    max-width: 380px;
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .search-tips-btn {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0.2rem 0.4rem;
    transition: color 0.2s;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Karla', sans-serif;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.6rem;
  }
  .search-tips-btn:hover { color: var(--ink); }
  .search-tips-btn::before { content: '?'; font-weight: 600; }

  .search-tips {
    background: var(--bg-panel);
    border: 1px solid var(--rule);
    padding: 1rem 1.2rem;
    margin-bottom: 0.8rem;
    font-family: 'Libre Baskerville', serif;
    font-size: 0.75rem;
    line-height: 1.9;
    color: var(--muted);
    font-style: italic;
    display: none;
  }
  .search-tips.visible { display: block; }
  .search-tips strong {
    color: var(--ink);
    font-weight: 600;
    font-style: normal;
  }

  .search-input-wrap {
    position: relative;
  }

  .search-input {
    width: 100%;
    background: var(--search-bg);
    border: 1px solid var(--search-border);
    color: var(--ink);
    font-family: 'Karla', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    padding: 0.8rem 1rem 0.8rem 2.6rem;
    outline: none;
    transition: border-color 0.2s, background 0.3s;
    box-sizing: border-box;
  }
  .search-input::placeholder { color: var(--muted); }
  .search-input:focus { border-color: var(--muted); }

  .search-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-size: 0.85rem;
    pointer-events: none;
    line-height: 1;
  }

  .search-results {
    position: absolute;
    top: calc(100% + 2px);
    left: 0; right: 0;
    background: var(--bg-panel);
    border: 1px solid var(--search-border);
    border-top: none;
    max-height: 280px;
    overflow-y: auto;
    z-index: 50;
    display: none;
  }
  .search-results.open { display: block; }

  .search-result-item {
    display: block;
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
    transition: background 0.1s;
  }
  .search-result-item:last-child { border-bottom: none; }
  .search-result-item:hover { background: var(--stat-hover); }

  .sri-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1rem;
    font-weight: 300;
    display: block;
  }
  .sri-meta {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 0.2rem;
    display: block;
  }

  .search-empty {
    padding: 0.9rem 1rem;
    font-size: 0.78rem;
    color: var(--muted);
    font-style: italic;
    font-family: 'Libre Baskerville', Georgia, serif;
  }

  /* ─── LEFT: CTA ─────────────────────────────────────────────── */
  .hero-cta {
    margin-top: auto;
    padding-top: 3rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn {
    font-family: 'Karla', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--btn-bg);
    color: var(--btn-ink);
    border: none;
    padding: 0.9rem 1.8rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s;
  }
  .btn:hover { opacity: 0.75; }

  .btn-ghost {
    font-family: 'Karla', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: none;
    color: var(--muted);
    border: 1px solid var(--rule);
    padding: 0.9rem 1.8rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost:hover { color: var(--ink); border-color: var(--muted); }

  /* ─── RIGHT: FEATURED POEM ──────────────────────────────────── */
  .featured-label {
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .featured-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--rule);
  }

  .featured-poem {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .featured-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.2rem;
    font-weight: 600;
    margin-bottom: 2rem;
    color: var(--ink);
    text-decoration: none;
    display: block;
    transition: color 0.2s;
    line-height: 1.2;
  }
  .featured-title:hover { color: var(--accent); }

  .featured-body {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.1rem;
    line-height: 2.3;
    color: var(--ink);
  }
  .featured-body p { margin: 0 0 0.15rem 0; }
  .featured-body p.stanza-break { margin-bottom: 1.2rem; }

  .featured-footer {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .tag {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: var(--tag-bg);
    color: var(--tag-ink);
    padding: 0.3rem 0.75rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .tag:hover { background: var(--rule); }

  .refresh-btn {
    margin-left: auto;
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: none;
    border: none;
    outline: none;
    box-shadow: none;
    -webkit-appearance: none;
    appearance: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .refresh-btn::before { content: '↻'; font-size: 0.9rem; }
  .refresh-btn:hover { color: var(--ink); }

  /* Bookmark and Send buttons */
  .bookmark-btn, .send-btn {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .bookmark-btn::before { content: '♡'; font-size: 1.05rem; }
  .bookmark-btn.bookmarked::before { content: '♥'; }
  .bookmark-btn:hover, .send-btn:hover { color: var(--ink); }
  
  .send-btn::before { content: '↗'; font-size: 0.9rem; }

  /* Send modal (shared with poem page) */
  .send-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 2000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .send-modal.open {
    display: flex;
  }

  .send-panel {
    background: var(--bg);
    border: 1px solid var(--rule);
    max-width: 460px;
    width: 100%;
    padding: 2.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .send-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .send-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--ink);
  }

  .send-close {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0.2rem 0.5rem;
    line-height: 1;
    transition: color 0.2s;
  }
  .send-close:hover {
    color: var(--ink);
  }

  .send-options {
    display: grid;
    gap: 0.8rem;
  }

  .send-option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: none;
    border: 1px solid var(--rule);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s, border-color 0.15s;
    text-decoration: none;
    color: var(--ink);
  }
  .send-option:hover {
    background: var(--bg-panel);
    border-color: var(--muted);
  }

  .send-icon {
    font-size: 1.4rem;
    line-height: 1;
    width: 24px;
    text-align: center;
    flex-shrink: 0;
  }

  .send-label {
    flex: 1;
  }

  .send-label-title {
    font-family: 'Karla', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 0.2rem;
  }

  .send-label-desc {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.7rem;
    color: var(--muted);
    font-style: italic;
  }

  .copy-feedback {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--ink);
    color: var(--bg);
    padding: 0.8rem 1.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-radius: 4px;
    z-index: 3000;
    display: none;
  }
  .copy-feedback.show {
    display: block;
    animation: fadeInOut 2s ease;
  }

  @keyframes fadeInOut {
    0% { opacity: 0; transform: translateX(-50%) translateY(10px); }
    15% { opacity: 1; transform: translateX(-50%) translateY(0); }
    85% { opacity: 1; transform: translateX(-50%) translateY(0); }
    100% { opacity: 0; transform: translateX(-50%) translateY(10px); }
  }

  /* ─── STATS ─────────────────────────────────────────────────── */
  .stats {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border-bottom: 1px solid var(--rule);
  }

  .stat {
    padding: 2rem 2.5rem;
    border-right: 1px solid var(--rule);
    text-decoration: none;
    color: var(--ink);
    transition: background 0.15s;
    display: block;
  }
  .stat:last-child { border-right: none; }
  .stat:hover { background: var(--stat-hover); }

  .stat-num {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.6rem;
    font-weight: 300;
    display: block;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 0.5rem;
    display: block;
  }

  /* ─── RESPONSIVE ────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; }
    .hero-left { 
      border-right: none; 
      border-bottom: 1px solid var(--rule); 
      padding: 3rem 2rem 2.5rem; 
    }
    .hero-right { padding: 3rem 2rem; }
    .stats { grid-template-columns: repeat(3, 1fr); }
    .stat { padding: 1.5rem 1.2rem; }
    .stat:nth-child(3) { border-right: none; }
    .stat:nth-child(4) { border-top: 1px solid var(--rule); }
    .stat:nth-child(5) { border-top: 1px solid var(--rule); }
    .search-wrap { max-width: 100%; }
    .hero-desc { max-width: 100%; }
    .hero-cta {
      padding-top: 2rem;
      gap: 1rem;
    }
    .btn, .btn-ghost {
      width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 500px) {
    .hero-left {
      padding: 2rem 1.5rem;
    }
    .hero-right {
      padding: 2rem 1.5rem;
    }
    .stat {
      padding: 1.2rem 0.8rem;
    }
    .stat-num {
      font-size: 2rem;
    }
    .send-panel {
      padding: 2rem 1.5rem;
    }
  }
</style>

<section class="hero">
  <div class="hero-left">
    <div>
      <h1 class="hero-title">Barking</h1>
      <div class="hero-byline">{total} poems</div>
      <p class="hero-desc">
        A collection of sounds and sentences — organised in different ways —
        essentially no different from barkings of a dog
       
      </p>

      <!-- Search -->
      <div class="search-wrap">
        <div class="search-header">
          <button class="search-tips-btn" id="search-tips-btn" aria-label="Show search tips">Tips</button>
        </div>
        <div class="search-tips" id="search-tips" role="region" aria-live="polite">
          Search by <strong>title</strong>, <strong>domain</strong>, <strong>atmosphere</strong>, <strong>crux</strong>, or combinations like <em>"silence stark"</em> or <em>"nondual groundlessness"</em>
        </div>
        <div class="search-input-wrap">
          <span class="search-icon" aria-hidden="true">⌕</span>
          <input
            type="text"
            class="search-input"
            id="search-input"
            placeholder="Search poems, domains, atmospheres…"
            autocomplete="off"
            aria-label="Search poems"
          />
        </div>
        <div class="search-results" id="search-results" role="listbox"></div>
      </div>
    </div>

    <div class="hero-cta">
      <a href={`${base}/browse`} class="btn">Browse the collection</a>
      <button class="btn-ghost" id="random-btn">Random poem →</button>
    </div>
  </div>

  <div class="hero-right">
    <div class="featured-label">Featured</div>
    <div class="featured-poem" id="featured"></div>
  </div>
</section>

<div class="stats">
  <a href={`${base}/cloud#domains`} class="stat">
    <span class="stat-num">{domainCount}</span>
    <span class="stat-label">Domains</span>
  </a>
  <a href={`${base}/cloud#atmosphere`} class="stat">
    <span class="stat-num">{atmosphereCount}</span>
    <span class="stat-label">Atmospheres</span>
  </a>
  <a href={`${base}/cloud#crux`} class="stat">
    <span class="stat-num">{cruxCount}</span>
    <span class="stat-label">Cruxes</span>
  </a>
  <a href={`${base}/cloud#ground`} class="stat">
    <span class="stat-num">{groundCount}</span>
    <span class="stat-label">Grounds</span>
  </a>
  <a href={`${base}/browse`} class="stat">
    <span class="stat-num">{total}</span>
    <span class="stat-label">Poems</span>
  </a>
</div>

<!-- Send Modal -->
<div class="send-modal" id="send-modal" role="dialog" aria-labelledby="send-title" aria-modal="true">
  <div class="send-panel">
    <div class="send-header">
      <h2 class="send-title" id="send-title">Send</h2>
      <button class="send-close" id="send-close" aria-label="Close send menu">×</button>
    </div>
    <div class="send-options">
      <button class="send-option" id="copy-link" data-action="copy">
        <div class="send-icon">🔗</div>
        <div class="send-label">
          <div class="send-label-title">Copy Link</div>
          <div class="send-label-desc">Copy URL to clipboard</div>
        </div>
      </button>
      <a class="send-option" id="email-send" data-action="email">
        <div class="send-icon">✉️</div>
        <div class="send-label">
          <div class="send-label-title">Email</div>
          <div class="send-label-desc">Send via email</div>
        </div>
      </a>
      <a class="send-option" id="twitter-send" target="_blank" rel="noopener noreferrer">
        <div class="send-icon">𝕏</div>
        <div class="send-label">
          <div class="send-label-title">Post on X</div>
          <div class="send-label-desc">Send on X (Twitter)</div>
        </div>
      </a>
      <button class="send-option" id="native-send" data-action="native" style="display: none;">
        <div class="send-icon">↗</div>
        <div class="send-label">
          <div class="send-label-title">Send...</div>
          <div class="send-label-desc">Use device send menu</div>
        </div>
      </button>
    </div>
  </div>
</div>

<!-- Copy feedback toast -->
<div class="copy-feedback" id="copy-feedback">Link copied to clipboard</div>

<script define:vars={{ searchIndex, featuredPool: featuredPoolFinal, base, siteUrl }}>

  // ── HTML sanitiser — prevents <> in search queries breaking the layout ─────
  function escapeHtml(str) {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ── Highlight matched query text in a result title ─────────────────────────
  function highlight(text, q) {
    const safe = escapeHtml(text);
    const escapedQ = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const re = new RegExp(`(${escapedQ})`, 'gi');
    return safe.replace(re, '<mark style="background:var(--accent);color:var(--bg)">$1</mark>');
  }

  // ── Bookmark management ────────────────────────────────────────────────────
  function getBookmarks() {
    try {
      return JSON.parse(localStorage.getItem('barking-bookmarks') || '[]');
    } catch {
      return [];
    }
  }

  function isBookmarked(slug) {
    return getBookmarks().includes(slug);
  }

  function toggleBookmark(slug) {
    const bookmarks = getBookmarks();
    const idx = bookmarks.indexOf(slug);
    if (idx > -1) {
      bookmarks.splice(idx, 1);
    } else {
      bookmarks.push(slug);
    }
    localStorage.setItem('barking-bookmarks', JSON.stringify(bookmarks));
    return idx === -1; // returns true if now bookmarked
  }

  // ── Send modal state ────────────────────────────────────────────────────
  let currentPoemSlug = '';
  let currentPoemTitle = '';

  // ── Featured poem ──────────────────────────────────────────────────────────
  const pool = featuredPool.slice().sort(() => Math.random() - 0.5);
  let idx = 0;

  function renderFeatured(poem) {
    currentPoemSlug = poem.slug;
    currentPoemTitle = poem.title;

    const lines = poem.content.split('\n').filter(l => !l.startsWith('#'));
    while (lines.length && !lines[0].trim()) lines.shift();
    while (lines.length && !lines[lines.length - 1].trim()) lines.pop();
    const bodyHtml = lines.map(l =>
      l.trim() ? `<p>${escapeHtml(l)}</p>` : `<p class="stanza-break"></p>`
    ).join('');

    const tagHtml = poem.tags.slice(0, 3).map(t =>
      `<a href="${base}/browse?tag=${encodeURIComponent(t)}" class="tag">${escapeHtml(t)}</a>`
    ).join('');

    const bookmarked = isBookmarked(poem.slug);
    const bookmarkBtn = `<button class="bookmark-btn ${bookmarked ? 'bookmarked' : ''}" 
                                 id="bookmark-featured-btn" 
                                 data-slug="${poem.slug}"
                                 aria-label="${bookmarked ? 'Remove bookmark' : 'Bookmark this poem'}">
                           ${bookmarked ? 'saved' : 'save'}
                         </button>`;

    const sendBtn = `<button class="send-btn" id="send-featured-btn" aria-label="Send this poem">send</button>`;

    const nextBtn = pool.length > 1
      ? `<button class="refresh-btn" id="next-poem-btn">another poem</button>`
      : '';

    document.getElementById('featured').innerHTML = `
      <a href="${base}/poem/${poem.slug}" class="featured-title">${escapeHtml(poem.title)}</a>
      <div class="featured-body">${bodyHtml}</div>
      <div class="featured-footer">
        ${tagHtml}
        ${bookmarkBtn}
        ${sendBtn}
        ${nextBtn}
      </div>
    `;
    
    // Attach bookmark handler
    const bookmarkBtnEl = document.getElementById('bookmark-featured-btn');
    if (bookmarkBtnEl) {
      bookmarkBtnEl.addEventListener('click', function() {
        const nowBookmarked = toggleBookmark(this.dataset.slug);
        this.classList.toggle('bookmarked', nowBookmarked);
        this.textContent = nowBookmarked ? 'saved' : 'save';
        this.setAttribute('aria-label', nowBookmarked ? 'Remove bookmark' : 'Bookmark this poem');
      });
    }

    // Attach send handler
    const sendBtnEl = document.getElementById('send-featured-btn');
    if (sendBtnEl) {
      sendBtnEl.addEventListener('click', openSendModal);
    }

    if (pool.length > 1) {
      document.getElementById('next-poem-btn').addEventListener('click', nextPoem);
    }
  }

  function nextPoem() {
    idx = (idx + 1) % pool.length;
    renderFeatured(pool[idx]);
  }

  renderFeatured(pool[idx]);

  document.getElementById('random-btn').addEventListener('click', () => {
    const rand = pool[Math.floor(Math.random() * pool.length)];
    window.location.href = `${base}/poem/${rand.slug}`;
  });

  // ── Search tips toggle ─────────────────────────────────────────────────────
  const tipsBtn = document.getElementById('search-tips-btn');
  const tipsEl  = document.getElementById('search-tips');
  
  tipsBtn.addEventListener('click', () => {
    tipsEl.classList.toggle('visible');
    const isVisible = tipsEl.classList.contains('visible');
    tipsBtn.setAttribute('aria-expanded', isVisible);
    tipsBtn.textContent = isVisible ? 'Hide tips' : 'Tips';
  });

  // ── Search with fuzzy matching ─────────────────────────────────────────────
  const input   = document.getElementById('search-input');
  const results = document.getElementById('search-results');

  // Simple fuzzy matching: allow 1 character difference for terms > 4 chars
  function fuzzyMatch(text, query) {
    text = text.toLowerCase();
    query = query.toLowerCase();
    
    if (text.includes(query)) return true;
    
    // Only fuzzy match if query is long enough
    if (query.length <= 4) return false;
    
    // Check if it's close enough (Levenshtein distance <= 1)
    if (Math.abs(text.length - query.length) > 1) return false;
    
    let differences = 0;
    const maxLen = Math.max(text.length, query.length);
    
    for (let i = 0; i < maxLen; i++) {
      if (text[i] !== query[i]) differences++;
      if (differences > 1) return false;
    }
    
    return differences <= 1;
  }

  function searchPoems(q) {
    return searchIndex.filter(p => {
      const lowerQ = q.toLowerCase();
      
      // Exact matches
      if (p.title.toLowerCase().includes(lowerQ)) return true;
      if (p.preview && p.preview.toLowerCase().includes(lowerQ)) return true;
      if (p.tags.some(t => t.toLowerCase().includes(lowerQ))) return true;
      if (p.domains.some(t => t.toLowerCase().includes(lowerQ))) return true;
      if (p.atmosphere.some(m => m.toLowerCase().includes(lowerQ))) return true;
      if (p.crux.some(f => f.toLowerCase().includes(lowerQ))) return true;
      
      // Fuzzy matches for taxonomy terms
      const allTerms = [...p.domains, ...p.atmosphere, ...p.crux, ...p.tags];
      return allTerms.some(term => fuzzyMatch(term, q));
    });
  }

  input.addEventListener('input', () => {
    const q = input.value.trim();
    if (q.length < 2) { 
      results.classList.remove('open'); 
      return; 
    }

    const matches = searchPoems(q).slice(0, 7);

    if (!matches.length) {
      results.innerHTML = `<div class="search-empty">No poems found for "${escapeHtml(q)}"</div>`;
    } else {
      results.innerHTML = matches.map(p => {
        const meta = [...p.atmosphere, ...p.crux, ...p.domains.slice(0, 2)]
          .filter(Boolean).join(' · ');
        return `<a href="${base}/poem/${p.slug}" class="search-result-item" role="option">
          <span class="sri-title">${highlight(p.title, q)}</span>
          ${meta ? `<span class="sri-meta">${escapeHtml(meta)}</span>` : ''}
        </a>`;
      }).join('');
    }
    results.classList.add('open');
  });

  document.addEventListener('click', e => {
    if (!e.target.closest('.search-wrap')) results.classList.remove('open');
  });

  input.addEventListener('keydown', e => {
    if (e.key === 'Escape') { 
      results.classList.remove('open'); 
      input.blur(); 
    }
    if (e.key === 'Tab') { 
      results.classList.remove('open'); 
    }
    if (e.key === 'Enter') {
      const first = results.querySelector('.search-result-item');
      if (first) window.location.href = first.href;
    }
  });

  // ── Send functionality ─────────────────────────────────────────────────────
  const sendModal = document.getElementById('send-modal');
  const sendClose = document.getElementById('send-close');
  const copyLinkBtn = document.getElementById('copy-link');
  const emailSend = document.getElementById('email-send');
  const twitterSend = document.getElementById('twitter-send');
  const nativeSendBtn = document.getElementById('native-send');
  const copyFeedback = document.getElementById('copy-feedback');

  // Check if native send is available (mobile devices)
  if (navigator.share) {
    nativeSendBtn.style.display = 'flex';
  }

  function openSendModal() {
    const poemUrl = `${siteUrl}/poem/${currentPoemSlug}/`;
    const sendText = `${currentPoemTitle} — a poem from Barking by Anatta Nergui`;
    
    // Email send
    const emailSubject = encodeURIComponent(sendText);
    const emailBody = encodeURIComponent(`I thought you might enjoy this poem:\n\n${currentPoemTitle}\n\n${poemUrl}`);
    emailSend.href = `mailto:?subject=${emailSubject}&body=${emailBody}`;

    // Twitter/X send
    const tweetText = encodeURIComponent(`"${currentPoemTitle}" — from Barking by Anatta Nergui\n\n${poemUrl}`);
    twitterSend.href = `https://twitter.com/intent/tweet?text=${tweetText}`;

    // Store current URL for copy
    copyLinkBtn.dataset.url = poemUrl;
    nativeSendBtn.dataset.url = poemUrl;
    nativeSendBtn.dataset.text = sendText;

    sendModal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  // Close modal
  function closeModal() {
    sendModal.classList.remove('open');
    document.body.style.overflow = '';
  }

  sendClose.addEventListener('click', closeModal);
  sendModal.addEventListener('click', (e) => {
    if (e.target === sendModal) closeModal();
  });

  // Escape key closes modal
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sendModal.classList.contains('open')) {
      closeModal();
    }
  });

  // Copy link
  copyLinkBtn.addEventListener('click', async () => {
    const url = copyLinkBtn.dataset.url;
    try {
      await navigator.clipboard.writeText(url);
      copyFeedback.classList.add('show');
      setTimeout(() => copyFeedback.classList.remove('show'), 2000);
    } catch (err) {
      // Fallback for older browsers
      const textArea = document.createElement('textarea');
      textArea.value = url;
      textArea.style.position = 'fixed';
      textArea.style.left = '-999999px';
      document.body.appendChild(textArea);
      textArea.select();
      try {
        document.execCommand('copy');
        copyFeedback.classList.add('show');
        setTimeout(() => copyFeedback.classList.remove('show'), 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
      document.body.removeChild(textArea);
    }
  });

  // Native send (mobile)
  if (nativeSendBtn) {
    nativeSendBtn.addEventListener('click', async () => {
      try {
        await navigator.share({
          title: nativeSendBtn.dataset.text,
          text: nativeSendBtn.dataset.text,
          url: nativeSendBtn.dataset.url
        });
        closeModal();
      } catch (err) {
        if (err.name !== 'AbortError') {
          console.error('Send failed:', err);
        }
      }
    });
  }
</script>
</Base>
