---
import Base from '../layouts/Base.astro';
import { getAllPoems, getAllPoemsMeta } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://anattanergui.github.io/barking';

const poems = getAllPoemsMeta();
const total = poems.length;

// Search index: meta only, no content — keeps the client bundle lean.
const searchIndex = poems.map(p => ({
  slug:       p.slug,
  title:      p.title,
  tags:       p.tags,
  domains:    p.domains,
  atmosphere: p.atmosphere,
  crux:       p.crux,
  preview:    p.preview,
  wordCount:  p.wordCount,
}));

// Featured pool: short poems only.
// Use frontmatter word-count if set, otherwise count from content.
// Criteria: fewer than 60 words AND fewer than 15 non-blank lines.
function contentStats(content) {
  const lines = content
    .split('\n')
    .filter(l => l.trim() && !l.startsWith('#')); // non-blank, non-heading
  const words = content
    .replace(/#+[^\n]*/g, '')   // strip headings
    .trim()
    .split(/\s+/)
    .filter(Boolean).length;
  return { lines: lines.length, words };
}

const featuredPool = getAllPoems()
  .filter(p => {
    // Trust frontmatter wordCount if present and non-zero
    const wc = p.wordCount && p.wordCount > 0
      ? p.wordCount
      : contentStats(p.content).words;
    const { lines } = contentStats(p.content);
    return wc > 0 && wc < 60 && lines < 15;
  })
  .map(p => ({ slug: p.slug, title: p.title, tags: p.tags, content: p.content }));

// Fallback: if no poems pass the filter yet, use all poems (showing preview as content)
const featuredPoolFinal = featuredPool.length > 0
  ? featuredPool
  : searchIndex.map(p => ({ slug: p.slug, title: p.title, tags: p.tags, content: p.preview }));
---

<Base title="Barking">
<style is:global>
  /* ─── LAYOUT ────────────────────────────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - var(--nav-h, 56px));
    border-bottom: 1px solid var(--rule);
  }

  .hero-left {
    padding: 5rem 4rem 4rem 5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-right: 1px solid var(--rule);
  }

  .hero-right {
    padding: 5rem 5rem 4rem 4rem;
    display: flex;
    flex-direction: column;
    background: var(--bg-panel);
    transition: background 0.3s;
  }

  /* ─── LEFT: TYPOGRAPHY ──────────────────────────────────────── */
  .hero-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(4rem, 6vw, 7rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }

  .hero-byline {
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 2rem;
    line-height: 2;
  }

  .hero-desc {
    margin-top: 1.8rem;
    max-width: 380px;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.05rem;
    line-height: 2;
    color: var(--muted);
    font-style: italic;
  }

  /* ─── SEARCH ────────────────────────────────────────────────── */
  .search-wrap {
    margin-top: 2.5rem;
    position: relative;
    max-width: 380px;
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .search-input-wrap {
    position: relative;
  }

  .search-input {
    width: 100%;
    background: var(--search-bg);
    border: 1px solid var(--search-border);
    color: var(--ink);
    font-family: 'Karla', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    padding: 0.8rem 1rem 0.8rem 2.6rem;
    outline: none;
    transition: border-color 0.2s, background 0.3s;
    box-sizing: border-box;
  }
  .search-input::placeholder { color: var(--muted); }
  .search-input:focus { border-color: var(--muted); }

  .search-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-size: 0.85rem;
    pointer-events: none;
    line-height: 1;
  }

  .search-results {
    position: absolute;
    top: calc(100% + 2px);
    left: 0; right: 0;
    background: var(--bg-panel);
    border: 1px solid var(--search-border);
    border-top: none;
    max-height: 280px;
    overflow-y: auto;
    z-index: 50;
    display: none;
  }
  .search-results.open { display: block; }

  .search-result-item {
    display: block;
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
    transition: background 0.1s;
  }
  .search-result-item:last-child { border-bottom: none; }
  .search-result-item:hover { background: var(--stat-hover); }

  .sri-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1rem;
    font-weight: 300;
    display: block;
  }
  .sri-meta {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 0.2rem;
    display: block;
  }

  .search-empty {
    padding: 0.9rem 1rem;
    font-size: 0.78rem;
    color: var(--muted);
    font-style: italic;
    font-family: 'Libre Baskerville', Georgia, serif;
  }

  /* ─── LEFT: CTA ─────────────────────────────────────────────── */
  .hero-cta {
    margin-top: auto;
    padding-top: 3rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn {
    font-family: 'Karla', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--btn-bg);
    color: var(--btn-ink);
    border: none;
    padding: 0.9rem 1.8rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s;
  }
  .btn:hover { opacity: 0.75; }

  .btn-ghost {
    font-family: 'Karla', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: none;
    color: var(--muted);
    border: 1px solid var(--rule);
    padding: 0.9rem 1.8rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost:hover { color: var(--ink); border-color: var(--muted); }

  /* ─── RIGHT: FEATURED POEM ──────────────────────────────────── */
  .featured-label {
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .featured-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--rule);
  }

  .featured-poem {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .featured-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.2rem;
    font-weight: 600;
    margin-bottom: 2rem;
    color: var(--ink);
    text-decoration: none;
    display: block;
    transition: color 0.2s;
    line-height: 1.2;
  }
  .featured-title:hover { color: var(--accent); }

  .featured-body {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.1rem;
    line-height: 2.3;
    color: var(--ink);
  }
  .featured-body p { margin: 0 0 0.15rem 0; }
  .featured-body p.stanza-break { margin-bottom: 1.2rem; }

  .featured-footer {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .tag {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: var(--tag-bg);
    color: var(--tag-ink);
    padding: 0.3rem 0.75rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .tag:hover { background: var(--rule); }

  .refresh-btn {
    margin-left: auto;
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: none;
    border: none;
    outline: none;
    box-shadow: none;
    -webkit-appearance: none;
    appearance: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .refresh-btn::before { content: '↻'; font-size: 0.9rem; }
  .refresh-btn:hover { color: var(--ink); }

  /* Bookmark and Send buttons */
  .bookmark-btn, .send-btn {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .bookmark-btn::before { content: '✒'; font-size: 1.05rem; }
  .bookmark-btn.bookmarked::before { content: '✒'; }
  .bookmark-btn:hover, .send-btn:hover { color: var(--ink); }
  
  .send-btn::before { content: '↗'; font-size: 0.9rem; }

  /* Send modal (shared with poem page) */
  /* Send dropdown - appears directly below the button */
  .send-dropdown {
    display: none;
    position: absolute;
    bottom: 100%;
    left: 0;
    margin-bottom: 0.5rem;
    background: var(--bg-panel);
    border: 1px solid var(--rule);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    z-index: 1000;
    min-width: 200px;
  }
  
  .send-dropdown.open {
    display: block;
  }

  .send-option {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.9rem 1.1rem;
    background: none;
    border: none;
    border-bottom: 1px solid var(--rule);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
    text-decoration: none;
    color: var(--ink);
    width: 100%;
    font-family: 'Karla', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  
  .send-option:last-child {
    border-bottom: none;
  }
  
  .send-option:hover {
    background: var(--stat-hover);
  }

  .send-icon {
    font-size: 1.1rem;
    line-height: 1;
    width: 20px;
    text-align: center;
    flex-shrink: 0;
  }

  /* Featured actions need position relative for dropdown */
  .featured-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    position: relative;
  }

  .copy-feedback {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--ink);
    color: var(--bg);
    padding: 0.8rem 1.5rem;
    font-family: 'Karla', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-radius: 4px;
    z-index: 3000;
    display: none;
  }
  .copy-feedback.show {
    display: block;
    animation: fadeInOut 2s ease;
  }

  @keyframes fadeInOut {
    0% { opacity: 0; transform: translateX(-50%) translateY(10px); }
    15% { opacity: 1; transform: translateX(-50%) translateY(0); }
    85% { opacity: 1; transform: translateX(-50%) translateY(0); }
    100% { opacity: 0; transform: translateX(-50%) translateY(10px); }
  }


  /* ─── RESPONSIVE ────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; }
    .hero-left { 
      border-right: none; 
      border-bottom: 1px solid var(--rule); 
      padding: 3rem 2rem 2.5rem; 
    }
    .hero-right { padding: 3rem 2rem; }
    .search-wrap { max-width: 100%; }
    .hero-desc { max-width: 100%; }
    .hero-cta {
      padding-top: 2rem;
      gap: 1rem;
    }
    .btn, .btn-ghost {
      width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 500px) {
    .hero-left {
      padding: 2rem 1.5rem;
    }
    .hero-right {
      padding: 2rem 1.5rem;
    }
    .send-panel {
      padding: 2rem 1.5rem;
    }
  }
</style>

<section class="hero">
  <div class="hero-left">
    <div>
      <h1 class="hero-title">Barking</h1>
      <div class="hero-byline">{total} poems</div>
      <p class="hero-desc">
        A collection of sounds and sentences — organised in different ways —
        essentially no different from barkings of a dog
       
      </p>

      <!-- Search -->
      <div class="search-wrap">
        <div class="search-input-wrap">
          <span class="search-icon" aria-hidden="true">⌕</span>
          <input
            type="text"
            class="search-input"
            id="search-input"
            placeholder="Search poems..."
            autocomplete="off"
            aria-label="Search poems"
          />
        </div>
        <div class="search-results" id="search-results" role="listbox"></div>
      </div>
    </div>

    <div class="hero-cta">
      <a href={`${base}/browse`} class="btn">Browse the collection</a>
      <button class="btn-ghost" id="random-btn">Random poem →</button>
    </div>
  </div>

  <div class="hero-right">
    <div class="featured-label">Featured</div>
    <div class="featured-poem" id="featured"></div>
  </div>
</section>



<!-- Copy feedback toast -->
<div class="copy-feedback" id="copy-feedback">Link copied to clipboard</div>

<script define:vars={{ searchIndex, featuredPool: featuredPoolFinal, base, siteUrl }}>

  // ── HTML sanitiser — prevents <> in search queries breaking the layout ─────
  function escapeHtml(str) {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ── Highlight matched query text in a result title ─────────────────────────
  function highlight(text, q) {
    const safe = escapeHtml(text);
    const escapedQ = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const re = new RegExp(`(${escapedQ})`, 'gi');
    return safe.replace(re, '<mark style="background:var(--accent);color:var(--bg)">$1</mark>');
  }

  // ── Bookmark management ────────────────────────────────────────────────────
  function getBookmarks() {
    try {
      return JSON.parse(localStorage.getItem('barking-bookmarks') || '[]');
    } catch {
      return [];
    }
  }

  function isBookmarked(slug) {
    return getBookmarks().includes(slug);
  }

  function toggleBookmark(slug) {
    const bookmarks = getBookmarks();
    const idx = bookmarks.indexOf(slug);
    if (idx > -1) {
      bookmarks.splice(idx, 1);
    } else {
      bookmarks.push(slug);
    }
    localStorage.setItem('barking-bookmarks', JSON.stringify(bookmarks));
    return idx === -1; // returns true if now bookmarked
  }

  // ── Send modal state ────────────────────────────────────────────────────
  let currentPoemSlug = '';
  let currentPoemTitle = '';

  // ── Featured poem ──────────────────────────────────────────────────────────
  const pool = featuredPool.slice().sort(() => Math.random() - 0.5);
  let idx = 0;

  function renderFeatured(poem) {
    currentPoemSlug = poem.slug;
    currentPoemTitle = poem.title;

    const lines = poem.content.split('\n').filter(l => !l.startsWith('#'));
    while (lines.length && !lines[0].trim()) lines.shift();
    while (lines.length && !lines[lines.length - 1].trim()) lines.pop();
    const bodyHtml = lines.map(l =>
      l.trim() ? `<p>${escapeHtml(l)}</p>` : `<p class="stanza-break"></p>`
    ).join('');

    const tagHtml = poem.tags.slice(0, 3).map(t =>
      `<a href="${base}/browse?tag=${encodeURIComponent(t)}" class="tag">${escapeHtml(t)}</a>`
    ).join('');

    const bookmarked = isBookmarked(poem.slug);
    const bookmarkBtn = `<button class="bookmark-btn ${bookmarked ? 'bookmarked' : ''}" 
                                 id="bookmark-featured-btn" 
                                 data-slug="${poem.slug}"
                                 aria-label="${bookmarked ? 'Remove mark' : 'Mark this poem'}">
                           ${bookmarked ? 'marked' : 'mark'}
                         </button>`;

    const sendDropdown = `
      <div style="position: relative;">
        <button class="send-btn" id="send-featured-btn" aria-label="Send this poem">send</button>
        <div class="send-dropdown" id="send-featured-dropdown">
          <button class="send-option" data-action="copy">
            <span class="send-icon">🔗</span>
            <span>Copy Link</span>
          </button>
          <a class="send-option" data-action="email" href="">
            <span class="send-icon">✉️</span>
            <span>Email</span>
          </a>
          <a class="send-option" data-action="twitter" href="" target="_blank" rel="noopener noreferrer">
            <span class="send-icon">𝕏</span>
            <span>Post on X</span>
          </a>
          <a class="send-option" data-action="facebook" href="" target="_blank" rel="noopener noreferrer">
            <span class="send-icon">f</span>
            <span>Facebook</span>
          </a>
          <a class="send-option" data-action="whatsapp" href="" target="_blank" rel="noopener noreferrer">
            <span class="send-icon">💬</span>
            <span>WhatsApp</span>
          </a>
        </div>
      </div>
    `;

    const nextBtn = pool.length > 1
      ? `<button class="refresh-btn" id="next-poem-btn">another poem</button>`
      : '';

    document.getElementById('featured').innerHTML = `
      <a href="${base}/poem/${poem.slug}" class="featured-title">${escapeHtml(poem.title)}</a>
      <div class="featured-body">${bodyHtml}</div>
      <div class="featured-footer">
        ${bookmarkBtn}
        ${sendDropdown}
        ${nextBtn}
      </div>
    `;
    
    // Attach bookmark handler
    const bookmarkBtnEl = document.getElementById('bookmark-featured-btn');
    if (bookmarkBtnEl) {
      bookmarkBtnEl.addEventListener('click', function() {
        const nowBookmarked = toggleBookmark(this.dataset.slug);
        this.classList.toggle('bookmarked', nowBookmarked);
        this.textContent = nowBookmarked ? 'marked' : 'mark';
        this.setAttribute('aria-label', nowBookmarked ? 'Remove mark' : 'Mark this poem');
      });
    }

    // Attach send dropdown handler
    const sendBtnEl = document.getElementById('send-featured-btn');
    const sendDropdownEl = document.getElementById('send-featured-dropdown');
    
    if (sendBtnEl && sendDropdownEl) {
      // Toggle dropdown
      sendBtnEl.addEventListener('click', (e) => {
        e.stopPropagation();
        sendDropdownEl.classList.toggle('open');
      });

      // Setup share URLs
      const poemUrl = `${siteUrl}${base}/poem/${poem.slug}`;
      const shareText = `${poem.title} — a poem from Barking by Anatta Nergui`;

      // Find dropdown options
      const copyBtn = sendDropdownEl.querySelector('[data-action="copy"]');
      const emailLink = sendDropdownEl.querySelector('[data-action="email"]');
      const twitterLink = sendDropdownEl.querySelector('[data-action="twitter"]');
      const facebookLink = sendDropdownEl.querySelector('[data-action="facebook"]');
      const whatsappLink = sendDropdownEl.querySelector('[data-action="whatsapp"]');
      const nativeBtn = null;

      // Email link
      if (emailLink) {
        const emailSubject = encodeURIComponent(shareText);
        const emailBody = encodeURIComponent(`I thought you might enjoy this poem:\n\n${poem.title}\n\n${poemUrl}`);
        emailLink.href = `mailto:?subject=${emailSubject}&body=${emailBody}`;
        emailLink.addEventListener('click', () => {
          setTimeout(() => sendDropdownEl.classList.remove('open'), 100);
        });
      }

      // Twitter link
      if (twitterLink) {
        const tweetText = encodeURIComponent(`"${poem.title}" — from Barking by Anatta Nergui\n\n${poemUrl}`);
        twitterLink.href = `https://twitter.com/intent/tweet?text=${tweetText}`;
        twitterLink.addEventListener('click', () => {
          setTimeout(() => sendDropdownEl.classList.remove('open'), 100);
        });
      }

      // Facebook link
      if (facebookLink) {
        facebookLink.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(poemUrl)}`;
        facebookLink.addEventListener('click', () => {
          setTimeout(() => sendDropdownEl.classList.remove('open'), 100);
        });
      }

      // WhatsApp link
      if (whatsappLink) {
        const waText = encodeURIComponent(`${poem.title} — from Barking by Anatta Nergui\n${poemUrl}`);
        whatsappLink.href = `https://wa.me/?text=${waText}`;
        whatsappLink.addEventListener('click', () => {
          setTimeout(() => sendDropdownEl.classList.remove('open'), 100);
        });
      }

      // Copy link
      if (copyBtn) {
        copyBtn.addEventListener('click', async (e) => {
          e.preventDefault();
          e.stopPropagation();
          try {
            await navigator.clipboard.writeText(poemUrl);
            showCopyFeedback();
            sendDropdownEl.classList.remove('open');
          } catch (err) {
            // Fallback
            const textArea = document.createElement('textarea');
            textArea.value = poemUrl;
            textArea.style.position = 'fixed';
            textArea.style.left = '-999999px';
            document.body.appendChild(textArea);
            textArea.select();
            try {
              document.execCommand('copy');
              showCopyFeedback();
            } catch (err) {
              console.error('Failed to copy:', err);
            }
            document.body.removeChild(textArea);
            sendDropdownEl.classList.remove('open');
          }
        });
      }

      // Native share (mobile)
      if (nativeBtn && navigator.share) {
        nativeBtn.style.display = 'flex';
        nativeBtn.addEventListener('click', async (e) => {
          e.preventDefault();
          e.stopPropagation();
          try {
            await navigator.share({
              title: shareText,
              text: shareText,
              url: poemUrl
            });
            sendDropdownEl.classList.remove('open');
          } catch (err) {
            if (err.name !== 'AbortError') {
              console.error('Share failed:', err);
            }
          }
        });
      }

      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!sendDropdownEl.contains(e.target) && e.target !== sendBtnEl) {
          sendDropdownEl.classList.remove('open');
        }
      });

      // Close on escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && sendDropdownEl.classList.contains('open')) {
          sendDropdownEl.classList.remove('open');
        }
      });
    }

    if (pool.length > 1) {
      document.getElementById('next-poem-btn').addEventListener('click', nextPoem);
    }
  }

  function nextPoem() {
    idx = (idx + 1) % pool.length;
    renderFeatured(pool[idx]);
  }

  renderFeatured(pool[idx]);

  document.getElementById('random-btn').addEventListener('click', () => {
    const rand = pool[Math.floor(Math.random() * pool.length)];
    window.location.href = `${base}/poem/${rand.slug}`;
  });

  // ── Search with multi-word matching ────────────────────────────────────────
  const input   = document.getElementById('search-input');
  const results = document.getElementById('search-results');

  function searchPoems(q) {
    // Split query into individual words
    const words = q.toLowerCase().split(/\s+/).filter(Boolean);
    
    const matches = searchIndex.filter(p => {
      // Combine all searchable text for this poem
      const searchable = [
        p.title,
        p.preview || '',
        ...p.tags,
        ...p.domains,
        ...p.atmosphere,
        ...p.crux
      ].join(' ').toLowerCase();
      
      // Poem must contain ALL words from the query
      return words.every(word => searchable.includes(word));
    });

    // Sort: exact title matches first, then title-starts-with, then rest
    return matches.sort((a, b) => {
      const aTitle = a.title.toLowerCase();
      const bTitle = b.title.toLowerCase();
      const qLower = q.toLowerCase();
      if (aTitle === qLower && bTitle !== qLower) return -1;
      if (bTitle === qLower && aTitle !== qLower) return 1;
      if (aTitle.startsWith(qLower) && !bTitle.startsWith(qLower)) return -1;
      if (bTitle.startsWith(qLower) && !aTitle.startsWith(qLower)) return 1;
      return 0;
    });
  }

  input.addEventListener('input', () => {
    const q = input.value.trim();
    if (q.length < 2) { 
      results.classList.remove('open'); 
      return; 
    }

    const matches = searchPoems(q).slice(0, 7);

    if (!matches.length) {
      results.innerHTML = `<div class="search-empty">No poems found for "${escapeHtml(q)}"</div>`;
    } else {
      results.innerHTML = matches.map(p => {
        const meta = [...p.atmosphere, ...p.crux, ...p.domains.slice(0, 2)]
          .filter(Boolean).join(' · ');
        return `<a href="${base}/poem/${p.slug}" class="search-result-item" role="option">
          <span class="sri-title">${highlight(p.title, q)}</span>
          ${meta ? `<span class="sri-meta">${escapeHtml(meta)}</span>` : ''}
        </a>`;
      }).join('');
    }
    results.classList.add('open');
  });

  document.addEventListener('click', e => {
    if (!e.target.closest('.search-wrap')) results.classList.remove('open');
  });

  input.addEventListener('keydown', e => {
    if (e.key === 'Escape') { 
      results.classList.remove('open'); 
      input.blur(); 
    }
    if (e.key === 'Tab') { 
      results.classList.remove('open'); 
    }
    if (e.key === 'Enter') {
      const first = results.querySelector('.search-result-item');
      if (first) window.location.href = first.href;
    }
  });

  // ── Copy feedback helper ───────────────────────────────────────────────────
  const copyFeedback = document.getElementById('copy-feedback');
  
  function showCopyFeedback() {
    if (copyFeedback) {
      copyFeedback.classList.add('show');
      setTimeout(() => copyFeedback.classList.remove('show'), 2000);
    }
  }
</script>
</Base>
