---
import Base from '../layouts/Base.astro';
import { getAllPoemsMeta } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allPoems = getAllPoemsMeta();
---
<Base
  title="Bookmarks"
  description="Your saved poems from Barking"
>
<style>
  .bookmarks-container {
    max-width: 780px;
    margin: 0 auto;
    padding: 5rem 2rem;
  }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    font-weight: 300;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    color: var(--ink);
  }

  .subtitle {
    font-family: 'Karla', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 3rem;
  }

  .empty-state {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.95rem;
    line-height: 2;
    color: var(--muted);
    font-style: italic;
    padding: 3rem 0;
    text-align: center;
  }

  .empty-state a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
  }
  .empty-state a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .bookmarks-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .bookmark-item {
    border-bottom: 1px solid var(--rule);
    transition: background 0.15s;
  }
  .bookmark-item:first-child {
    border-top: 1px solid var(--rule);
  }
  .bookmark-item:hover {
    background: var(--stat-hover);
  }

  .bookmark-link {
    display: block;
    padding: 1.2rem 1.5rem;
    text-decoration: none;
    color: var(--ink);
  }

  .bookmark-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 300;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }
  .bookmark-item:hover .bookmark-title {
    color: var(--accent);
  }

  .bookmark-meta {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .bookmark-actions {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    display: flex;
    gap: 1rem;
  }

  .btn-ghost {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: none;
    color: var(--muted);
    border: 1px solid var(--rule);
    padding: 0.7rem 1.2rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost:hover {
    color: var(--ink);
    border-color: var(--muted);
  }

  @media (max-width: 700px) {
    .bookmarks-container {
      padding: 3rem 1.5rem;
    }
    h1 {
      font-size: 2.2rem;
    }
    .bookmark-link {
      padding: 1rem;
    }
  }
</style>

<div class="bookmarks-container">
  <h1>Bookmarks</h1>
  <p class="subtitle" id="bookmark-count">Loading...</p>

  <div id="bookmarks-content">
    <div class="empty-state">
      Loading your bookmarks...
    </div>
  </div>

  <div class="bookmark-actions" id="bookmark-actions" style="display: none;">
    <button class="btn-ghost" id="clear-all-btn">Clear all bookmarks</button>
    <button class="btn-ghost" id="export-btn">Export as JSON</button>
  </div>
</div>

<script define:vars={{ allPoems, base }}>
  function getBookmarks() {
    try {
      const data = localStorage.getItem('barking-bookmarks');
      if (!data) return [];
      return JSON.parse(data);
    } catch (e) {
      console.error('Failed to read bookmarks:', e);
      return [];
    }
  }

  function saveBookmarks(bookmarks) {
    try {
      localStorage.setItem('barking-bookmarks', JSON.stringify(bookmarks));
      return true;
    } catch (e) {
      console.error('Failed to save bookmarks:', e);
      return false;
    }
  }

  function renderBookmarks() {
    const bookmarkSlugs = getBookmarks();
    const countEl = document.getElementById('bookmark-count');
    const contentEl = document.getElementById('bookmarks-content');
    const actionsEl = document.getElementById('bookmark-actions');

    if (bookmarkSlugs.length === 0) {
      countEl.textContent = 'No bookmarks yet';
      contentEl.innerHTML = `
        <div class="empty-state">
          You haven't saved any poems yet. Click the "Save" button at the end of any poem to bookmark it.<br><br>
          <a href="${base}/browse">Browse the collection →</a>
        </div>
      `;
      actionsEl.style.display = 'none';
      return;
    }

    countEl.textContent = `${bookmarkSlugs.length} poem${bookmarkSlugs.length !== 1 ? 's' : ''} saved`;

    // Get poem details for bookmarked slugs
    const bookmarkedPoems = bookmarkSlugs
      .map(slug => allPoems.find(p => p.slug === slug))
      .filter(Boolean);

    if (bookmarkedPoems.length === 0) {
      contentEl.innerHTML = `
        <div class="empty-state">
          No matching poems found. Your bookmarks may reference deleted poems.
        </div>
      `;
      actionsEl.style.display = 'none';
      return;
    }

    contentEl.innerHTML = `
      <ul class="bookmarks-list">
        ${bookmarkedPoems.map(poem => {
          const meta = [...(poem.atmosphere || []), ...(poem.crux || []), ...(poem.domains || []).slice(0, 2)]
            .filter(Boolean)
            .slice(0, 3)
            .join(' · ');
          
          return `
            <li class="bookmark-item">
              <a href="${base}/poem/${poem.slug}" class="bookmark-link">
                <div class="bookmark-title">${poem.title}</div>
                ${meta ? `<div class="bookmark-meta">${meta}</div>` : ''}
              </a>
            </li>
          `;
        }).join('')}
      </ul>
    `;

    actionsEl.style.display = 'flex';
  }

  function clearAllBookmarks() {
    if (confirm('Are you sure you want to clear all bookmarks? This cannot be undone.')) {
      saveBookmarks([]);
      renderBookmarks();
    }
  }

  function exportBookmarks() {
    const bookmarks = getBookmarks();
    const data = JSON.stringify(bookmarks, null, 2);
    const blob = new Blob([data], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'barking-bookmarks.json';
    a.click();
    URL.revokeObjectURL(url);
  }

  // Initialize
  renderBookmarks();

  // Event listeners
  const clearBtn = document.getElementById('clear-all-btn');
  const exportBtn = document.getElementById('export-btn');
  
  if (clearBtn) clearBtn.addEventListener('click', clearAllBookmarks);
  if (exportBtn) exportBtn.addEventListener('click', exportBookmarks);
</script>
</Base>
