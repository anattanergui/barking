    padding: 1.6rem 1.4rem 1rem;
    border-bottom: 1px solid var(--rule);
    flex-shrink: 0;
  }
  .sidebar-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--ink);
    margin: 0 0 0.15rem;
    line-height: 1;
  }
  .sidebar-sub {
    font-size: 0.57rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .mode-tabs {
    display: flex;
