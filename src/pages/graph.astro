    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-right: 0.6rem;
    flex-shrink: 0;
  }
  .hub-sort-btn {
    font-size: 0.55rem;
    letter-spacing: 0.14em;
