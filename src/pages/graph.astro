  .accordion-search:focus { border-color: var(--muted); }
  .accordion-search::placeholder { color: var(--muted); opacity: 0.6; }

  .value-list {
    display: flex;
    flex-direction: column;
    max-height: 220px;
    overflow-y: auto;
  }
  .value-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.32rem 1.4rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Karla', sans-serif;
    font-size: 0.78rem;
    color: var(--muted);
    text-align: left;
    transition: background 0.1s, color 0.1s;
  }
  .value-btn:hover  { background: var(--stat-hover); color: var(--ink); }
  .value-btn.active { background: var(--stat-hover); color: var(--ink); font-weight: 500; }

  .value-count {
    font-size: 0.62rem;
    color: var(--rule);
