---
import Base from '../layouts/Base.astro';
import { getAllPoems } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/,'');

const poems = getAllPoems();

// ── Nodes ────────────────────────────────────────────────────────────────────
const nodes = poems.map(p => ({
  id:         p.slug,
  label:      p.title,
  domains:    p.domains    || [],
  atmosphere: p.atmosphere || [],
  tags:       p.tags       || [],
  crux:       p.crux       || [],
  ground:     p.ground     || [],
  related:    p.related    || [],
  preview:    p.preview    || '',
}));

// ── Edges: shared values across all fields, max 10 per node ──────────────────
const FIELDS = ['domains','atmosphere','tags','crux','ground'];
const edgeMap = new Map();
const degree  = new Map(nodes.map(n => [n.id, 0]));

function addEdge(slugA, slugB, field, value) {
  if ((degree.get(slugA)||0) >= 10 || (degree.get(slugB)||0) >= 10) return;
  const key = [slugA, slugB].sort().join('||');
  if (!edgeMap.has(key)) {
    edgeMap.set(key, { source: slugA, target: slugB, fields: new Set(), values: [] });
    degree.set(slugA, (degree.get(slugA)||0) + 1);
    degree.set(slugB, (degree.get(slugB)||0) + 1);
  }
  const e = edgeMap.get(key);
  e.fields.add(field);
  e.values.push(value);
}

for (let i = 0; i < nodes.length; i++) {
  const a = nodes[i];
  for (let j = i + 1; j < nodes.length; j++) {
    const b = nodes[j];
    FIELDS.forEach(f => {
      (a[f] || []).forEach(v => {
        if ((b[f] || []).includes(v)) addEdge(a.id, b.id, f, v);
      });
    });
  }
  (a.related || []).forEach(ref => {
    const target = nodes.find(n =>
      n.id === ref ||
      n.label.toLowerCase() === ref.toLowerCase() ||
      n.id === ref.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'')
    );
    if (target && target.id !== a.id) addEdge(a.id, target.id, 'related', ref);
  });
}

const edges = [...edgeMap.values()].map(e => ({
  source: e.source, target: e.target,
  fields: [...e.fields], values: e.values,
}));

// ── Hub index ────────────────────────────────────────────────────────────────
const hubIndex = {};

nodes.forEach(n => {
  FIELDS.forEach(f => {
    (n[f] || []).forEach(v => {
      const key = `${f}::${v}`;
      if (!hubIndex[key]) hubIndex[key] = { field: f, value: v, poems: [] };
      hubIndex[key].poems.push(n.id);
    });
  });
});

const hubsByField = {};
FIELDS.forEach(f => { hubsByField[f] = []; });
Object.values(hubIndex).forEach(h => {
  if (h.poems.length >= 1 && hubsByField[h.field]) {
    hubsByField[h.field].push(h);
  }
});
FIELDS.forEach(f => {
  hubsByField[f].sort((a, b) => a.value.localeCompare(b.value));
});

const graphData = JSON.stringify({ nodes, edges, hubsByField });
---

<Base title="Graph — Barking">
<style>
  .graph-page {
    display: grid;
    grid-template-columns: 240px 1fr;
    height: calc(100vh - var(--nav-h, 56px));
    overflow: hidden;
  }

  .sidebar {
    border-right: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--bg);
  }

  .sidebar-head {
    padding: 1.6rem 1.4rem 1rem;
    border-bottom: 1px solid var(--rule);
    flex-shrink: 0;
  }
  .sidebar-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--ink);
    margin: 0 0 0.15rem;
    line-height: 1;
  }
  .sidebar-sub {
    font-size: 0.57rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .mode-tabs {
    display: flex;
    border-bottom: 1px solid var(--rule);
    flex-shrink: 0;
  }
  .mode-tab {
    flex: 1;
    padding: 0.7rem 0;
    font-family: 'Karla', sans-serif;
    font-size: 0.63rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s;
  }
  .mode-tab:hover  { color: var(--ink); }
  .mode-tab.active { color: var(--ink); border-bottom-color: var(--ink); }

  .sidebar-panel {
    flex: 1;
    overflow-y: auto;
    display: none;
    flex-direction: column;
  }
  .sidebar-panel.active { display: flex; }

  .accordion-item {
    border-bottom: 1px solid var(--rule);
    flex-shrink: 0;
  }
  .accordion-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.75rem 1.4rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Karla', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: left;
    transition: color 0.15s, background 0.15s;
  }
  .accordion-trigger:hover { color: var(--ink); background: var(--stat-hover); }
  .accordion-trigger.open  { color: var(--ink); }

  .accordion-trigger-left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .field-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .fd-domains    { background: #7c9e87; }
  .fd-atmosphere { background: #a07080; }
  .fd-tags       { background: #7088a0; }
  .fd-crux       { background: #a09060; }
  .fd-ground     { background: #a08050; }

  .accordion-arrow {
    font-size: 0.6rem;
    transition: transform 0.2s;
    color: var(--muted);
  }
  .accordion-trigger.open .accordion-arrow { transform: rotate(180deg); }

  .accordion-body {
    display: none;
    flex-direction: column;
    padding: 0.3rem 0 0.5rem;
    background: var(--bg-panel);
  }
  .accordion-body.open { display: flex; }

  .accordion-search {
    margin: 0.4rem 1rem 0.5rem;
    padding: 0.4rem 0.6rem;
    font-size: 0.75rem;
    font-family: 'Karla', sans-serif;
    border: 1px solid var(--rule);
    background: var(--paper);
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s;
