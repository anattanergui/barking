---
import Base from '../layouts/Base.astro';
import { getAllPoems } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/,'');

const poems = getAllPoems();

// ── Nodes ────────────────────────────────────────────────────────────────────
const nodes = poems.map(p => ({
  id:         p.slug,
  label:      p.title,
  domains:    p.domains    || [],
  atmosphere: p.atmosphere || [],
  tags:       p.tags       || [],
  crux:       p.crux       || [],
  ground:     p.ground     || [],
  related:    p.related    || [],
  preview:    p.preview    || '',
}));

// ── Edges: shared values across all fields, max 10 per node ──────────────────
const FIELDS = ['domains','atmosphere','tags','crux','ground'];
const edgeMap = new Map();
const degree  = new Map(nodes.map(n => [n.id, 0]));

function addEdge(slugA, slugB, field, value) {
  if ((degree.get(slugA)||0) >= 10 || (degree.get(slugB)||0) >= 10) return;
  const key = [slugA, slugB].sort().join('||');
  if (!edgeMap.has(key)) {
    edgeMap.set(key, { source: slugA, target: slugB, fields: new Set(), values: [] });
    degree.set(slugA, (degree.get(slugA)||0) + 1);
    degree.set(slugB, (degree.get(slugB)||0) + 1);
  }
  const e = edgeMap.get(key);
  e.fields.add(field);
  e.values.push(value);
}

for (let i = 0; i < nodes.length; i++) {
  const a = nodes[i];
  for (let j = i + 1; j < nodes.length; j++) {
    const b = nodes[j];
    FIELDS.forEach(f => {
      (a[f] || []).forEach(v => {
        if ((b[f] || []).includes(v)) addEdge(a.id, b.id, f, v);
      });
    });
  }
  (a.related || []).forEach(ref => {
    const target = nodes.find(n =>
      n.id === ref ||
      n.label.toLowerCase() === ref.toLowerCase() ||
      n.id === ref.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'')
    );
    if (target && target.id !== a.id) addEdge(a.id, target.id, 'related', ref);
  });
}

const edges = [...edgeMap.values()].map(e => ({
  source: e.source, target: e.target,
  fields: [...e.fields], values: e.values,
}));

// ── Hub index ────────────────────────────────────────────────────────────────
const hubIndex = {};

nodes.forEach(n => {
  FIELDS.forEach(f => {
    (n[f] || []).forEach(v => {
      const key = `${f}::${v}`;
      if (!hubIndex[key]) hubIndex[key] = { field: f, value: v, poems: [] };
      hubIndex[key].poems.push(n.id);
    });
  });
});

const hubsByField = {};
FIELDS.forEach(f => { hubsByField[f] = []; });
Object.values(hubIndex).forEach(h => {
  if (h.poems.length >= 1 && hubsByField[h.field]) {
    hubsByField[h.field].push(h);
  }
});
// Sort by poem count descending (richest hubs first)
FIELDS.forEach(f => {
  hubsByField[f].sort((a, b) => b.poems.length - a.poems.length);
});

const graphData = JSON.stringify({ nodes, edges, hubsByField });
const graphDataB64 = Buffer.from(graphData).toString('base64');
---

<Base title="Graph — Barking">
<style>
  .graph-page {
    display: grid;
    grid-template-columns: 240px 1fr;
    height: calc(100vh - var(--nav-h, 56px));
