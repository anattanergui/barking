    border: none;
    cursor: pointer;
    padding: 0.55rem 0.5rem;
    font-family: 'Karla', sans-serif;
    transition: color 0.15s;
    border-bottom: 1.5px solid transparent;
    margin-bottom: -1px;
  }
  .hub-sort-btn:hover { color: var(--ink); }
  .hub-sort-btn.active { color: var(--ink); border-bottom-color: var(--ink); }

  /* ── Intersection mode bar ── */
