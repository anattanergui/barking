---
import Base from '../layouts/Base.astro';
import { getAllPoemsMeta } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allPoems = getAllPoemsMeta();
---
<Base
  title="Reading History"
  description="Recently read poems from Barking"
>
<style>
  .history-container {
    max-width: 780px;
    margin: 0 auto;
    padding: 5rem 2rem;
  }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    font-weight: 300;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    color: var(--ink);
  }

  .subtitle {
    font-family: 'Karla', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 3rem;
  }

  .empty-state {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.95rem;
    line-height: 2;
    color: var(--muted);
    font-style: italic;
    padding: 3rem 0;
    text-align: center;
  }

  .empty-state a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
  }
  .empty-state a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .history-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .history-item {
    border-bottom: 1px solid var(--rule);
    transition: background 0.15s;
    position: relative;
  }
  .history-item:first-child {
    border-top: 1px solid var(--rule);
  }
  .history-item:hover {
    background: var(--stat-hover);
  }

  .history-link {
    display: block;
    padding: 1.2rem 1.5rem;
    text-decoration: none;
    color: var(--ink);
  }

  .history-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 300;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }
  .history-item:hover .history-title {
    color: var(--accent);
  }

  .history-meta {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .recent-badge {
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Karla', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--accent);
  }

  .history-actions {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .btn-ghost {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: none;
    color: var(--muted);
    border: 1px solid var(--rule);
    padding: 0.7rem 1.2rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost:hover {
    color: var(--ink);
    border-color: var(--muted);
  }

  @media (max-width: 700px) {
    .history-container {
      padding: 3rem 1.5rem;
    }
    h1 {
      font-size: 2.2rem;
    }
    .history-link {
      padding: 1rem;
      padding-right: 5rem;
    }
    .recent-badge {
      right: 1rem;
    }
  }
</style>

<div class="history-container">
  <h1>Reading History</h1>
  <p class="subtitle" id="history-count">Loading...</p>

  <div id="history-content">
    <div class="empty-state">
      Loading your reading history...
    </div>
  </div>

  <div class="history-actions" id="history-actions" style="display: none;">
    <button class="btn-ghost" id="clear-history-btn">Clear history</button>
  </div>
</div>

<script define:vars={{ allPoems, base }}>
  function getHistory() {
    try {
      const data = localStorage.getItem('barking-history');
      if (!data) return [];
      return JSON.parse(data);
    } catch (e) {
      console.error('Failed to read history:', e);
      return [];
    }
  }

  function saveHistory(history) {
    try {
      localStorage.setItem('barking-history', JSON.stringify(history));
      return true;
    } catch (e) {
      console.error('Failed to save history:', e);
      return false;
    }
  }

  function renderHistory() {
    const historySlugs = getHistory();
    const countEl = document.getElementById('history-count');
    const contentEl = document.getElementById('history-content');
    const actionsEl = document.getElementById('history-actions');

    if (historySlugs.length === 0) {
      countEl.textContent = 'No reading history';
      contentEl.innerHTML = `
        <div class="empty-state">
          You haven't read any poems yet. Your reading history will appear here automatically as you explore the collection.<br><br>
          <a href="${base}/browse">Browse the collection →</a>
        </div>
      `;
      actionsEl.style.display = 'none';
      return;
    }

    countEl.textContent = `${historySlugs.length} poem${historySlugs.length !== 1 ? 's' : ''} read`;

    // Get poem details for history slugs
    const historyPoems = historySlugs
      .map(slug => allPoems.find(p => p.slug === slug))
      .filter(Boolean);

    if (historyPoems.length === 0) {
      contentEl.innerHTML = `
        <div class="empty-state">
          No matching poems found in your history.
        </div>
      `;
      actionsEl.style.display = 'none';
      return;
    }

    contentEl.innerHTML = `
      <ul class="history-list">
        ${historyPoems.map((poem, index) => {
          const meta = [...(poem.atmosphere || []), ...(poem.crux || []), ...(poem.domains || []).slice(0, 2)]
            .filter(Boolean)
            .slice(0, 3)
            .join(' · ');
          
          const isRecent = index === 0;
          
          return `
            <li class="history-item">
              <a href="${base}/poem/${poem.slug}" class="history-link">
                <div class="history-title">${poem.title}</div>
                ${meta ? `<div class="history-meta">${meta}</div>` : ''}
              </a>
              ${isRecent ? '<div class="recent-badge">Last Read</div>' : ''}
            </li>
          `;
        }).join('')}
      </ul>
    `;

    actionsEl.style.display = 'block';
  }

  function clearHistory() {
    if (confirm('Are you sure you want to clear your reading history? This cannot be undone.')) {
      saveHistory([]);
      renderHistory();
    }
  }

  // Initialize
  renderHistory();

  // Event listener
  const clearBtn = document.getElementById('clear-history-btn');
  if (clearBtn) clearBtn.addEventListener('click', clearHistory);
</script>
</Base>
