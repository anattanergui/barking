---
import Base from '../layouts/Base.astro';
import { getAllPoemsMeta } from '../lib/poems.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allPoems = getAllPoemsMeta();
---
<Base
  title="Reading History"
  description="Recently read poems from Barking"
>
<style>
  .history-container {
    max-width: 780px;
    margin: 0 auto;
    padding: 5rem 2rem;
  }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    font-weight: 300;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    color: var(--ink);
  }

  .subtitle {
    font-family: 'Karla', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .privacy-notice {
    font-family: 'Karla', sans-serif;
    font-size: 0.7rem;
    line-height: 1.6;
    color: var(--muted);
    margin-bottom: 3rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--rule);
    background: var(--bg-panel);
  }

  .empty-state {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.95rem;
    line-height: 2;
    color: var(--muted);
    font-style: italic;
    padding: 3rem 0;
    text-align: center;
  }

  .empty-state a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
  }
  .empty-state a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .history-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule);
  }

  .history-item {
    border-bottom: 1px solid var(--rule);
    position: relative;
  }

  .history-link {
    display: block;
    padding: 1.8rem 1.5rem;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.15s;
  }
  .history-link:hover {
    background: var(--stat-hover);
  }

  .history-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 300;
    line-height: 1.3;
    transition: color 0.2s;
  }
  .history-link:hover .history-title {
    color: var(--accent);
  }

  .history-timestamp {
    font-family: 'Karla', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--rule);
    margin-top: 0.6rem;
  }

  .history-actions {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-ghost {
    font-family: 'Karla', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: none;
    color: var(--muted);
    border: 1px solid var(--rule);
    padding: 0.7rem 1.2rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost:hover {
    color: var(--ink);
    border-color: var(--muted);
  }

  @media (max-width: 700px) {
    .history-container {
      padding: 3rem 1.5rem;
    }
    h1 {
      font-size: 2.2rem;
    }
    .history-link {
      padding: 1.5rem 1rem;
    }
    .privacy-notice {
      font-size: 0.65rem;
      padding: 0.9rem 1rem;
    }
  }
</style>

<div class="history-container">
  <h1>Reading History</h1>
  <p class="subtitle" id="history-count">Loading...</p>
  <div class="privacy-notice">
    Your reading history is stored locally on this device only. Nothing is collected, tracked, or sent to any server.
  </div>

  <div id="history-content">
    <div class="empty-state">
      Loading your history...
    </div>
  </div>

  <div class="history-actions" id="history-actions" style="display: none;">
    <button class="btn-ghost" id="clear-all-btn">Clear all history</button>
    <button class="btn-ghost" id="export-btn">Export as JSON</button>
  </div>
</div>

<script define:vars={{ allPoems, base }}>
  const MAX_HISTORY = 100;

  function getHistory() {
    try {
      const data = localStorage.getItem('barking-history');
      if (!data) return [];
      return JSON.parse(data);
    } catch (e) {
      console.error('Failed to read history:', e);
      return [];
    }
  }

  function saveHistory(history) {
    try {
      localStorage.setItem('barking-history', JSON.stringify(history));
      return true;
    } catch (e) {
      console.error('Failed to save history:', e);
      return false;
    }
  }

  function formatTimestamp(timestamp) {
    const date = new Date(timestamp);
    const now = new Date();
    const diffMs = now - date;
    const diffMins = Math.floor(diffMs / (1000 * 60));
    const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
    const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
    
    if (diffMins < 1) return 'Just now';
    if (diffMins < 60) return `${diffMins} min${diffMins !== 1 ? 's' : ''} ago`;
    if (diffHours < 24) return `${diffHours} hour${diffHours !== 1 ? 's' : ''} ago`;
    if (diffDays === 1) return 'Yesterday';
    if (diffDays < 7) return `${diffDays} days ago`;
    if (diffDays < 30) return `${Math.floor(diffDays / 7)} week${Math.floor(diffDays / 7) !== 1 ? 's' : ''} ago`;
    
    // Format as "Jan 15"
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    return `${months[date.getMonth()]} ${date.getDate()}`;
  }

  function renderHistory() {
    const history = getHistory();
    const countEl = document.getElementById('history-count');
    const contentEl = document.getElementById('history-content');
    const actionsEl = document.getElementById('history-actions');

    if (history.length === 0) {
      countEl.textContent = 'No history yet';
      contentEl.innerHTML = `
        <div class="empty-state">
          You haven't read any poems yet. Your reading history is stored locally on your device.<br><br>
          <a href="${base}/browse">Browse the collection →</a>
        </div>
      `;
      actionsEl.style.display = 'none';
      return;
    }

    // Get unique poems (most recent visit for each)
    const uniqueSlugs = [...new Set(history.map(h => h.slug))];
    const uniqueHistory = uniqueSlugs.map(slug => {
      const entries = history.filter(h => h.slug === slug);
      return entries[0]; // Most recent
    });

    countEl.textContent = `${uniqueHistory.length} poem${uniqueHistory.length !== 1 ? 's' : ''} read`;

    // Get poem details
    const historyPoems = uniqueHistory
      .map(entry => {
        const poem = allPoems.find(p => p.slug === entry.slug);
        return poem ? { ...entry, poem } : null;
      })
      .filter(Boolean);

    if (historyPoems.length === 0) {
      contentEl.innerHTML = `
        <div class="empty-state">
          No matching poems found. Your history may reference deleted poems.
        </div>
      `;
      actionsEl.style.display = 'none';
      return;
    }

    contentEl.innerHTML = `
      <ul class="history-list">
        ${historyPoems.map(entry => {
          const timestamp = formatTimestamp(entry.timestamp);
          return `
            <li class="history-item">
              <a href="${base}/poem/${entry.poem.slug}" class="history-link">
                <div class="history-title">${entry.poem.title}</div>
                <div class="history-timestamp">${timestamp}</div>
              </a>
            </li>
          `;
        }).join('')}
      </ul>
    `;

    actionsEl.style.display = 'flex';
  }

  // Clear all
  document.getElementById('clear-all-btn').addEventListener('click', () => {
    if (confirm('Are you sure you want to clear your reading history? This cannot be undone.')) {
      saveHistory([]);
      renderHistory();
    }
  });

  // Export
  document.getElementById('export-btn').addEventListener('click', () => {
    const history = getHistory();
    const exportData = {
      history,
      exportDate: new Date().toISOString()
    };
    const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `barking-history-${new Date().toISOString().split('T')[0]}.json`;
    a.click();
    URL.revokeObjectURL(url);
  });

  renderHistory();
</script>
</Base>
