---
import Base from '../layouts/Base.astro';
import { getAllPoemsMeta, getFilterOptions } from '../lib/poems.js';

const poems = getAllPoemsMeta();
const filters = getFilterOptions(poems);

const poemsJson = JSON.stringify(poems.map(p => ({
  slug:    p.slug,
  title:   p.title,
  mood:    p.mood,
  form:    p.form,
  themes:  p.themes,
  tags:    p.tags,
  preview: p.preview,
})));

// All tags (untruncated) — client-side JS handles show-more
const allTagsJson = JSON.stringify(filters.tags);
---
<Base title="Browse">
<style>
  .layout {
    display: grid;
    grid-template-columns: 270px 1fr;
    min-height: calc(100vh - var(--nav-h));
  }

  /* Sidebar */
  .sidebar {
    border-right: 1px solid var(--rule);
    padding: 2.5rem 1.8rem;
    position: sticky;
    top: var(--nav-h);
    height: calc(100vh - var(--nav-h));
    overflow-y: auto;
  }

  .search {
    width: 100%;
    padding: 0.65rem 0.9rem;
    font-size: 0.85rem;
    font-family: 'Karla', sans-serif;
    border: 1px solid var(--rule);
    background: var(--paper);
    color: var(--ink);
    outline: none;
    margin-bottom: 2rem;
    transition: border-color 0.2s;
  }
  .search:focus { border-color: var(--ink); }
  .search::placeholder { color: var(--muted); }

  .filter-group { margin-bottom: 2rem; }
  .filter-heading {
    font-size: 0.62rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--muted);
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0.8rem;
  }

  .filter-btn {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; padding: 0.4rem 0;
    font-size: 0.84rem;
    color: var(--muted);
    cursor: pointer;
    background: none; border: none;
    font-family: 'Karla', sans-serif;
    text-align: left;
    transition: color 0.15s;
    letter-spacing: 0.01em;
  }
  .filter-btn:hover { color: var(--ink); }
  .filter-btn.active { color: var(--ink); font-weight: 400; }
  .filter-btn.active .filter-name::before { content: '— '; color: var(--accent); }
  .filter-count { font-size: 0.7rem; color: var(--rule); }

  /* Tags show-more */
  .filter-btn.tag-hidden { display: none; }
  .show-more-btn {
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    cursor: pointer;
    background: none; border: none;
    font-family: 'Karla', sans-serif;
    margin-top: 0.4rem;
    padding: 0;
  }

  .clear-all {
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    cursor: pointer;
    background: none; border: none;
    font-family: 'Karla', sans-serif;
    margin-top: 0.5rem;
    display: none;
  }
  .clear-all.visible { display: block; }

  /* Main area */
  .main { padding: 2.5rem 3.5rem; }

  .browse-header {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--rule);
  }

  .result-count {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 300;
  }
  .result-count span { font-family: 'Karla', sans-serif; font-size: 0.85rem; color: var(--muted); }

  .sort-btns { display: flex; gap: 1.5rem; }
  .sort-btn {
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    background: none; border: none;
    font-family: 'Karla', sans-serif;
    transition: color 0.2s;
    padding-bottom: 2px;
  }
  .sort-btn.active {
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
  }

  /* Poem grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .card {
    padding: 2rem 1.8rem;
    border-bottom: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
    cursor: pointer;
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .card:hover { background: var(--paper-warm); }

  .card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1.25;
    margin-bottom: 0.5rem;
  }
  .card-meta {
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .card-preview {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.8rem;
    line-height: 1.9;
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-tags {
    margin-top: 1.1rem;
    display: flex; flex-wrap: wrap; gap: 0.35rem;
  }

  .empty {
    padding: 4rem;
    color: var(--muted);
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 0.9rem;
    grid-column: 1/-1;
  }

  @media (max-width: 900px) {
    .layout { grid-template-columns: 1fr; }
    .sidebar { position: static; height: auto; border-right: none; border-bottom: 1px solid var(--rule); }
    .main { padding: 2rem 1.5rem; }
  }
</style>

<div class="layout">
  <aside class="sidebar">
    <input class="search" type="text" placeholder="Search poems…" id="search" />

    <div class="filter-group">
      <div class="filter-heading">Theme</div>
      {filters.themes.map(([val, count]) => (
        <button class="filter-btn" data-type="theme" data-val={val}>
          <span class="filter-name">{val}</span>
          <span class="filter-count">{count}</span>
        </button>
      ))}
    </div>

    <div class="filter-group">
      <div class="filter-heading">Mood</div>
      {filters.moods.map(([val, count]) => (
        <button class="filter-btn" data-type="mood" data-val={val}>
          <span class="filter-name">{val}</span>
          <span class="filter-count">{count}</span>
        </button>
      ))}
    </div>

    <div class="filter-group">
      <div class="filter-heading">Form</div>
      {filters.forms.map(([val, count]) => (
        <button class="filter-btn" data-type="form" data-val={val}>
          <span class="filter-name">{val}</span>
          <span class="filter-count">{count}</span>
        </button>
      ))}
    </div>

    <!-- Tags rendered client-side so show-more works without JS hydration -->
    <div class="filter-group">
      <div class="filter-heading">Tags</div>
      <div id="tag-list"></div>
      <button class="show-more-btn" id="show-more-tags" style="display:none"></button>
    </div>

    <button class="clear-all" id="clear-all">Clear all filters</button>
  </aside>

  <main class="main">
    <div class="browse-header">
      <div class="result-count" id="count">… <span>poems</span></div>
      <div class="sort-btns">
        <button class="sort-btn active" data-sort="alpha">A–Z</button>
        <button class="sort-btn" data-sort="mood">By mood</button>
        <button class="sort-btn" data-sort="theme">By theme</button>
      </div>
    </div>
    <div class="grid" id="grid"></div>
  </main>
</div>

<script define:vars={{ poemsJson, allTagsJson }}>
  const ALL     = JSON.parse(poemsJson);
  const ALL_TAGS = JSON.parse(allTagsJson); // [[val, count], ...]
  const TAG_PREVIEW = 15;
  let tagsExpanded = false;

  // ── Active filter state ────────────────────────────────────────────────────
  // Initialise from URL so bookmarked/shared links restore correctly.
  const params = new URLSearchParams(location.search);
  let active = {
    theme: params.get('theme') || null,
    mood:  params.get('mood')  || null,
    form:  params.get('form')  || null,
    tag:   params.get('tag')   || null,
  };
  let sortMode = 'alpha';

  // ── URL sync ───────────────────────────────────────────────────────────────
  function syncURL() {
    const p = new URLSearchParams();
    Object.entries(active).forEach(([k, v]) => { if (v) p.set(k, v); });
    const qs = p.toString();
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
  }

  // ── Render tag list ────────────────────────────────────────────────────────
  function renderTags() {
    const visible = tagsExpanded ? ALL_TAGS : ALL_TAGS.slice(0, TAG_PREVIEW);
    const tagList = document.getElementById('tag-list');
    tagList.innerHTML = visible.map(([val, count]) => `
      <button
        class="filter-btn${active.tag === val ? ' active' : ''}"
        data-type="tag"
        data-val="${val.replace(/"/g, '&quot;')}"
      >
        <span class="filter-name">${active.tag === val ? '— ' : ''}${val}</span>
        <span class="filter-count">${count}</span>
      </button>
    `).join('');

    // Wire click handlers for freshly rendered tag buttons
    tagList.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => handleFilterClick(btn));
    });

    const showMoreBtn = document.getElementById('show-more-tags');
    if (ALL_TAGS.length > TAG_PREVIEW) {
      showMoreBtn.style.display = 'block';
      showMoreBtn.textContent = tagsExpanded
        ? `Show fewer`
        : `+${ALL_TAGS.length - TAG_PREVIEW} more`;
    } else {
      showMoreBtn.style.display = 'none';
    }
  }

  // ── Filter click handler (shared by static + dynamic buttons) ─────────────
  function handleFilterClick(btn) {
    const type = btn.dataset.type;
    const val  = btn.dataset.val;

    if (active[type] === val) {
      active[type] = null;
      btn.classList.remove('active');
    } else {
      // Deactivate siblings of the same type
      document.querySelectorAll(`[data-type="${type}"]`).forEach(b => b.classList.remove('active'));
      active[type] = val;
      btn.classList.add('active');
    }

    syncURL();
    updateClear();
    apply();

    // Re-render tags so active state reflects correctly
    if (type === 'tag') renderTags();
  }

  // ── Main filter + search ───────────────────────────────────────────────────
  function apply() {
    const q = document.getElementById('search').value.toLowerCase();
    let list = ALL.filter(p => {
      if (active.theme && !p.themes.includes(active.theme)) return false;
      if (active.mood  && !p.mood.includes(active.mood))    return false;
      if (active.form  && !p.form.includes(active.form))    return false;
      if (active.tag   && !p.tags.includes(active.tag))     return false;
      if (q && !p.title.toLowerCase().includes(q) && !p.preview.toLowerCase().includes(q)) return false;
      return true;
    });

    if (sortMode === 'alpha') list.sort((a, b) => a.title.localeCompare(b.title));
    else if (sortMode === 'mood')  list.sort((a, b) => (a.mood[0]  || '').localeCompare(b.mood[0]  || ''));
    else if (sortMode === 'theme') list.sort((a, b) => (a.themes[0] || '').localeCompare(b.themes[0] || ''));

    document.getElementById('count').innerHTML =
      `${list.length} <span>poem${list.length !== 1 ? 's' : ''}</span>`;

    const grid = document.getElementById('grid');
    if (list.length === 0) {
      grid.innerHTML = '<div class="empty">No poems match these filters.</div>';
      return;
    }

    grid.innerHTML = list.map(p => `
      <a href="/poem/${p.slug}" class="card">
        <div class="card-title">${p.title}</div>
        <div class="card-meta">${[...p.mood, ...p.form].filter(Boolean).join(' · ')}</div>
        <div class="card-preview">${p.preview}</div>
        <div class="card-tags">
          ${p.tags.slice(0, 3).map(t => `<span class="tag">${t}</span>`).join('')}
        </div>
      </a>
    `).join('');
  }

  // ── Static filter buttons (theme / mood / form) ────────────────────────────
  document.querySelectorAll('.filter-btn').forEach(btn => {
    const type = btn.dataset.type;
    if (active[type] === btn.dataset.val) btn.classList.add('active');
    btn.addEventListener('click', () => handleFilterClick(btn));
  });

  // ── Sort buttons ───────────────────────────────────────────────────────────
  document.querySelectorAll('.sort-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      sortMode = btn.dataset.sort;
      document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      apply();
    });
  });

  // ── Search ─────────────────────────────────────────────────────────────────
  const searchEl = document.getElementById('search');
  searchEl.addEventListener('input', apply);

  // Close dropdown on Tab (accessibility)
  searchEl.addEventListener('keydown', e => {
    if (e.key === 'Tab') searchEl.blur();
  });

  // ── Clear all ──────────────────────────────────────────────────────────────
  function updateClear() {
    const hasActive = Object.values(active).some(Boolean);
    document.getElementById('clear-all').classList.toggle('visible', hasActive);
  }

  document.getElementById('clear-all').addEventListener('click', () => {
    active = { theme: null, mood: null, form: null, tag: null };
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('search').value = '';
    syncURL();
    updateClear();
    renderTags();
    apply();
  });

  // ── Show more tags ─────────────────────────────────────────────────────────
  document.getElementById('show-more-tags').addEventListener('click', () => {
    tagsExpanded = !tagsExpanded;
    renderTags();
  });

  // ── Init ───────────────────────────────────────────────────────────────────
  renderTags();
  updateClear();
  apply();
</script>
</Base>
